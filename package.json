{
  "name": "nodetool",
  "private": true,
  "workspaces": [
    "packages/protocol",
    "packages/gpu",
    "packages/timeline",
    "packages/image-editor",
    "packages/kernel",
    "packages/runtime",
    "packages/models",
    "packages/node-sdk",
    "packages/base-nodes",
    "packages/dsl",
    "packages/sdk",
    "packages/code-runners",
    "packages/fal-codegen",
    "packages/fal-nodes",
    "packages/replicate-codegen",
    "packages/replicate-nodes",
    "packages/huggingface-nodes",
    "packages/elevenlabs-nodes",
    "packages/minimax-nodes",
    "packages/transformers-js-nodes",
    "packages/transformers-js-provider",
    "packages/websocket",
    "packages/agents",
    "packages/chat",
    "packages/security",
    "packages/huggingface",
    "packages/vectorstore",
    "packages/auth",
    "packages/cli",
    "packages/storage",
    "packages/config",
    "packages/deploy",
    "packages/compute",
    "packages/elevenlabs-nodes",
    "packages/kie-codegen",
    "packages/kie-nodes",
    "packages/topaz-nodes",
    "packages/reve-nodes",
    "packages/atlascloud-nodes",
    "packages/together-nodes",
    "packages/sandbox",
    "packages/sandbox-agent",
    "packages/sandbox-tools",
    "packages/workflow-runner",
    "packages/nodes-utils",
    "packages/core-nodes",
    "packages/text-nodes",
    "packages/llm-nodes",
    "packages/data-nodes",
    "packages/document-nodes",
    "packages/image-nodes",
    "packages/audio-nodes",
    "packages/video-nodes",
    "packages/integration-nodes",
    "packages/code-nodes",
    "packages/automation-nodes",
    "web",
    "electron",
    "demo",
    "examples/chat_app",
    "examples/nextjs-vercel",
    "examples/nextjs-cloudflare"
  ],
  "scripts": {
    "postinstall": "node electron/scripts/rebuild-native.mjs",
    "rebuild:native": "node electron/scripts/rebuild-native.mjs",
    "create:pack": "node scripts/create-pack.mjs",
    "preflight": "node scripts/preflight.mjs",
    "prebuild:packages": "node scripts/preflight.mjs",
    "build:packages": "turbo run build --filter=\"./packages/*\"",
    "prebuild:packages:clean": "node scripts/preflight.mjs",
    "build:packages:clean": "turbo run build --filter=\"./packages/*\" --force",
    "prebuild:packages:tsc": "node scripts/preflight.mjs",
    "build:packages:tsc": "tsc --build tsconfig.build.json && node scripts/copy-manifests.mjs",
    "build:web": "turbo run build --filter=web",
    "redeploy": "bash scripts/redeploy.sh",
    "build": "turbo run build",
    "test:packages": "turbo run test --filter=\"./packages/*\"",
    "turbo": "turbo",
    "turbo:build": "turbo run build",
    "turbo:build:packages": "turbo run build --filter=\"./packages/*\"",
    "turbo:test": "turbo run test",
    "turbo:test:packages": "turbo run test --filter=\"./packages/*\"",
    "turbo:lint": "turbo run lint",
    "turbo:typecheck": "turbo run typecheck",
    "turbo:check": "turbo run typecheck lint test",
    "dev": "concurrently --raw --kill-others-on-fail \"node scripts/dev-server.mjs\" \"npm run dev --workspace=web\"",
    "dev:fast": "npm run dev",
    "dev:web": "npm run dev --workspace=web",
    "dev:server": "node scripts/dev-server.mjs",
    "dev:server:fast": "npm run dev:server",
    "dev:dist": "turbo run dev --filter=@nodetool-ai/websocket --filter=nodetool",
    "dev:server:dist": "turbo run dev --filter=@nodetool-ai/websocket",
    "dev:watch": "npm run dev",
    "dev:watch:server": "npm run dev:server",
    "lint": "oxlint packages/*/src web/src electron mobile/src && npm run lint:design --workspace=web",
    "lint:fix": "oxlint packages/*/src web/src electron mobile/src --fix",
    "lint:packages": "oxlint packages/*/src",
    "lint:eslint": "eslint packages/*/src",
    "workflow": "node ./scripts/run-workflow.mjs",
    "chat": "node ./packages/cli/dist/index.js",
    "nodetool": "node ./packages/cli/dist/nodetool.js",
    "generate:node-docs": "node scripts/generate-node-docs.mjs && node scripts/build-node-index.mjs",
    "generate:node-index": "node scripts/build-node-index.mjs",
    "generate:fal": "npm run generate --workspace=packages/fal-codegen -- --strict",
    "generate:replicate": "npm run generate --workspace=packages/replicate-codegen -- --all --strict",
    "generate:kie": "npm run generate --workspace=packages/kie-codegen -- --all --refresh-configs",
    "generate:aki": "tsx packages/runtime/scripts/generate-aki-manifest.ts",
    "dev:chat": "NODE_OPTIONS='--conditions=nodetool-dev' tsx ./packages/cli/src/index.ts",
    "dev:workflow": "NODE_OPTIONS='--conditions=nodetool-dev' tsx ./packages/cli/src/nodetool.ts workflows run",
    "dev:nodetool": "NODE_OPTIONS='--conditions=nodetool-dev' tsx ./packages/cli/src/nodetool.ts",
    "bump-version": "node ./scripts/bump-version.mjs",
    "prepare-publish": "node ./scripts/prepare-publish.mjs",
    "install:all": "npm install && npm --prefix mobile install",
    "typecheck": "npm run typecheck:web && npm run typecheck:electron && npm run typecheck:mobile",
    "typecheck:web": "npm run typecheck --workspace=web",
    "typecheck:electron": "npm run typecheck --workspace=electron",
    "typecheck:mobile": "tsc --build packages/protocol && npm --prefix mobile run typecheck",
    "test": "npm run test:web && npm run test:electron && npm run test:mobile",
    "test:all": "turbo run test",
    "test:web": "npm test --workspace=web",
    "test:electron": "npm test --workspace=electron",
    "test:mobile": "npm --prefix mobile test",
    "test:watch": "npm run test:watch --workspace=web",
    "test:coverage": "npm run test:coverage:web && npm run test:coverage:electron && npm run test:coverage:mobile",
    "test:coverage:web": "npm run test:coverage --workspace=web",
    "test:coverage:electron": "npm run test:coverage --workspace=electron",
    "test:coverage:mobile": "npm --prefix mobile run test:coverage",
    "test:integration": "npm test --workspace=@nodetool-ai/base-nodes -- example-workflows-execute",
    "test:mutation": "for pkg in agents auth config kernel node-sdk runtime security storage; do npm run test:mutation --workspace=packages/$pkg || true; done",
    "mutation:score": "node scripts/mutation-score.mjs",
    "lint:web": "npm run lint --workspace=web",
    "lint:electron": "npm run lint --workspace=electron",
    "lint:mobile": "npm --prefix mobile run lint",
    "lint:fix:web": "npm run lint:fix --workspace=web",
    "lint:fix:electron": "npm run lint:fix --workspace=electron",
    "format": "npm run lint:fix",
    "check:deps": "node scripts/check-workspace-deps.mjs",
    "check:circular": "node scripts/check-circular-deps.mjs",
    "check:keys": "node scripts/check-key-boundaries.mjs",
    "check:coupled-deps": "node scripts/check-coupled-deps.mjs",
    "check": "npm run check:deps && npm run check:circular && npm run check:keys && npm run check:coupled-deps && npm run build:packages && npm run typecheck && npm run lint && npm run test:packages && npm run test",
    "clean": "npm run clean:build && node -e \"for(const p of ['node_modules','web/node_modules','electron/node_modules','mobile/node_modules']) require('fs').rmSync(p,{recursive:true,force:true})\"",
    "clean:build": "node -e \"for(const p of ['web/build','web/dist','electron/dist','electron/dist-electron']) require('fs').rmSync(p,{recursive:true,force:true})\"",
    "build:electron": "npm run build --workspace=electron",
    "build-stale-backend": "npm run build:stale --workspace=packages/websocket",
    "electron": "npm run build:web && npm run build:electron && npm start --workspace=electron",
    "electron:dev": "node scripts/electron-dev.mjs",
    "screenshots": "npm run build:packages && npm run screenshots --workspace=web",
    "screenshots:force": "npm run build:packages && npm run screenshots:force --workspace=web",
    "setup:codex": "bash scripts/setup-codex.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.4",
    "madge": "^8.0.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.0.0",
    "turbo": "^2.9.6",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "keytar": "^7.9.0",
    "msgpackr": "^1.11.9",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "packageManager": "npm@10.9.7"
}
