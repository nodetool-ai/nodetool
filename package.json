{
  "name": "nodetool",
  "private": true,
  "workspaces": [
    "packages/protocol",
    "packages/kernel",
    "packages/runtime",
    "packages/models",
    "packages/node-sdk",
    "packages/base-nodes",
    "packages/dsl",
    "packages/code-runners",
    "packages/fal-codegen",
    "packages/fal-nodes",
    "packages/replicate-codegen",
    "packages/replicate-nodes",
    "packages/elevenlabs-nodes",
    "packages/websocket",
    "packages/agents",
    "packages/chat",
    "packages/security",
    "packages/huggingface",
    "packages/vectorstore",
    "packages/auth",
    "packages/cli",
    "packages/storage",
    "packages/config",
    "packages/deploy",
    "packages/elevenlabs-nodes",
    "packages/kie-codegen",
    "packages/kie-nodes",
    "web",
    "electron"
  ],
  "scripts": {
    "postinstall": "node -e \"try{require('fs').unlinkSync('node_modules/.electron-native-rebuild-stamp')}catch{}\"",
    "build:packages": "turbo run build --filter=\"./packages/*\"",
    "build:packages:clean": "turbo run build --filter=\"./packages/*\" --force",
    "build:packages:tsc": "tsc --build tsconfig.build.json && node -e \"const fs=require('fs'); fs.cpSync('packages/replicate-nodes/src/replicate-manifest.json','packages/replicate-nodes/dist/replicate-manifest.json'); fs.cpSync('packages/fal-nodes/src/fal-manifest.json','packages/fal-nodes/dist/fal-manifest.json'); fs.cpSync('packages/kie-nodes/src/kie-manifest.json','packages/kie-nodes/dist/kie-manifest.json');\"",
    "build:web": "npm run build --workspace=web",
    "build": "turbo run build",
    "test:packages": "turbo run test --filter=\"./packages/*\"",
    "turbo": "turbo",
    "turbo:build": "turbo run build",
    "turbo:build:packages": "turbo run build --filter=\"./packages/*\"",
    "turbo:test": "turbo run test",
    "turbo:test:packages": "turbo run test --filter=\"./packages/*\"",
    "turbo:lint": "turbo run lint",
    "turbo:typecheck": "turbo run typecheck",
    "turbo:check": "turbo run typecheck lint test",
    "dev": "concurrently \"npm run dev --workspace=packages/websocket\" \"npm run start --workspace=web\"",
    "dev:fast": "concurrently \"npm run dev:fast --workspace=packages/websocket\" \"npm run start --workspace=web\"",
    "dev:web": "npm run start --workspace=web",
    "dev:server": "npm run dev --workspace=packages/websocket",
    "dev:server:fast": "npm run dev:fast --workspace=packages/websocket",
    "dev:watch": "concurrently \"node scripts/dev-server.mjs\" \"npm run start --workspace=web\"",
    "dev:watch:server": "node scripts/dev-server.mjs",
    "lint": "oxlint packages/*/src web/src electron mobile/src",
    "lint:fix": "oxlint packages/*/src web/src electron mobile/src --fix",
    "lint:packages": "oxlint packages/*/src",
    "lint:eslint": "eslint packages/*/src",
    "workflow": "node ./scripts/run-workflow.mjs",
    "chat": "node ./packages/cli/dist/index.js",
    "nodetool": "node ./packages/cli/dist/nodetool.js",
    "generate:fal": "npm run generate --workspace=packages/fal-codegen",
    "generate:replicate": "npm run generate --workspace=packages/replicate-codegen -- --all && npm run extract-manifest --workspace=packages/replicate-nodes",
    "generate:kie": "npm run generate --workspace=packages/kie-codegen -- --all",
    "dev:chat": "NODE_OPTIONS='--conditions=nodetool-dev' tsx ./packages/cli/src/index.ts",
    "dev:workflow": "NODE_OPTIONS='--conditions=nodetool-dev' tsx ./packages/cli/src/nodetool.ts workflows run",
    "dev:nodetool": "NODE_OPTIONS='--conditions=nodetool-dev' tsx ./packages/cli/src/nodetool.ts",
    "bump-version": "node ./scripts/bump-version.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.0.0",
    "eslint": "^10.0.3",
    "oxlint": "^1.60.0",
    "tsx": "^4.0.0",
    "turbo": "^2.9.6",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.118.0",
    "keytar": "^7.9.0",
    "msgpackr": "^1.11.9"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "packageManager": "npm@10.9.7"
}
