{
  "name": "nodetool-electron",
  "version": "0.7.0-rc.23",
  "private": true,
  "description": "node-based AI development tool",
  "homepage": "https://nodetool.ai",
  "main": "dist-electron/main.js",
  "scripts": {
    "start": "electron .",
    "start:devmode": "electron .",
    "chat": "electron . --chat",
    "prepare-backend": "node scripts/bundle-backend.mjs",
    "verify:python-packages": "node scripts/verify-python-packages.mjs",
    "verify:bundle": "node scripts/verify-bundle.mjs",
    "build": "tsc && vite build && node scripts/fetch-node-runtime.mjs && npm run prepare-backend && npm run verify:bundle && electron-builder",
    "vite:build": "vite build && node scripts/verify-bundle.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "check": "tsc && eslint . && jest",
    "dev": "vite",
    "preview": "vite preview",
    "predist": "npm run build",
    "dist": "electron-builder",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "node scripts/rebuild-native.mjs"
  },
  "author": "matti.georgi@gmail.com",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "39.8.10",
    "electron-builder": "26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^0.29.1"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@nodetool-ai/protocol": "*",
    "@nodetool-ai/websocket": "*",
    "@trpc/client": "^11.17.0",
    "better-sqlite3": "^12.10.0",
    "bufferutil": "^4.1.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.9",
    "superjson": "^2.2.6",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "qs": ">=6.14.1",
    "express": ">=4.21.2",
    "body-parser": ">=1.20.3",
    "rollup": "^4.59.0",
    "minimatch": ">=3.1.4",
    "undici": ">=6.24.0",
    "flatted": ">=3.4.2",
    "lodash": ">=4.17.23",
    "ajv": ">=6.14.0",
    "immutable": ">=3.8.3",
    "svgo": ">=3.3.3"
  },
  "permissions": [
    "audioCapture"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git"
  }
}
