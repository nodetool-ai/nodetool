{
  "name": "nodetool-electron",
  "version": "0.7.0-rc.1",
  "description": "node-based AI development tool",
  "homepage": "https://nodetool.ai",
  "main": "dist-electron/main.js",
  "scripts": {
    "start": "electron .",
    "start:devmode": "electron .",
    "chat": "electron . --chat",
    "prepare-backend": "node scripts/bundle-backend.mjs",
    "build": "tsc && vite build && npm run prepare-backend && electron-builder",
    "vite:build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "tsc && eslint . && jest",
    "dev": "vite",
    "preview": "vite preview",
    "predist": "npm run build",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "npm run test:integration --workspace=packages/websocket"
  },
  "author": "matti.georgi@gmail.com",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/compat": "^2.0.5",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "35.7.5",
    "electron-builder": "^26.3.4",
    "esbuild": "^0.27.4",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.29.0"
  },
  "optionalDependencies": {
    "dmg-license": "^1.0.11"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@msgpack/msgpack": "^3.0.0-beta2",
    "@nodetool/protocol": "*",
    "@openai/codex-sdk": "^0.118.0",
    "@opencode-ai/sdk": "^1.4.3",
    "better-sqlite3": "^12.9.0",
    "bufferutil": "^4.0.9",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.1.8",
    "js-yaml": "^4.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.4",
    "sqlite-vec": "^0.1.9-alpha.2",
    "ws": "^8.18.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.3"
  },
  "overrides": {
    "qs": ">=6.14.1",
    "express": ">=4.21.2",
    "body-parser": ">=1.20.3",
    "rollup": "^4.59.0",
    "minimatch": ">=3.1.4",
    "undici": ">=6.24.0",
    "flatted": ">=3.4.2",
    "lodash": ">=4.17.23",
    "ajv": ">=6.14.0",
    "immutable": ">=3.8.3",
    "svgo": ">=3.3.3"
  },
  "permissions": [
    "audioCapture"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git"
  }
}
