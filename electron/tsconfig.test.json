{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "baseUrl": ".",
    "types": ["react", "react-dom", "node", "jest"],
    "paths": {
      "@nodetool-ai/protocol": ["../packages/protocol/src/index.ts"],
      "@nodetool-ai/protocol/*": ["../packages/protocol/src/*"],
      "@nodetool-ai/websocket/trpc": ["src/__mocks__/websocket-trpc.ts"],
      "@nodetool-ai/config": ["../packages/config/src/index.ts"],
      "@nodetool-ai/config/*": ["../packages/config/src/*"]
    }
  },
  "include": [
    "src",
    "src/types/*.d.ts",
    "src/__tests__/**/*.ts",
    "src/__mocks__/**/*.ts",
    "src/main.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-web",
    "dist-electron",
    "out"
  ]
}