{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "envMode": "loose",
  // Pin the local cache to a fixed path (turbo's default) so CI can persist it
  // with actions/cache; see .github/actions/setup-build/action.yml.
  "cacheDir": ".turbo/cache",
  "globalDependencies": [
    "tsconfig.base.json",
    "tsconfig.build.json",
    "eslint.config.mjs",
    ".nvmrc",
    "package-lock.json",
    "scripts/build-typescript-workspace.mjs",
    "scripts/copy-manifests.mjs"
  ],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "scripts/**",
        "tsconfig*.json",
        "package.json",
        "src/**/*.json"
      ],
      "outputs": ["dist/**", "tsconfig.tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "__tests__/**",
        "tests/**",
        "test/**",
        "vitest.config.*",
        "jest.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": [],
      "env": ["NODETOOL_LOG_LEVEL"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsconfig*.json",
        "package.json",
        "eslint.config.*",
        ".eslintrc*"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:fast": {
      "cache": false,
      "persistent": true
    }
  }
}
