{
  "name": "@nodetool-ai/example-nextjs-cloudflare",
  "private": true,
  "version": "0.0.0",
  "description": "Next.js app that runs NodeTool workflows server-side on Cloudflare Workers (via OpenNext).",
  "scripts": {
    "dev": "next dev --port 3003",
    "build": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@nodetool-ai/core-nodes": "*",
    "@nodetool-ai/llm-nodes": "*",
    "@nodetool-ai/node-sdk": "*",
    "@nodetool-ai/protocol": "*",
    "@nodetool-ai/runtime": "*",
    "@nodetool-ai/workflow-runner": "*",
    "next": "^15.5.18",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.85.0"
  }
}
