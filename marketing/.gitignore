# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
/test-results
/playwright-report
/blob-report
/playwright/.cache

# next.js
/.next/
/out/

# showcase seeder batch output (assets + manifest.jsonl) — ingested into
