/seo/out/

# production
/build

# misc
.DS_Store
*.pem

# generated OG screenshots (run `npm run og:screenshots` to regenerate)
/public/og/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# opennext / cloudflare
/.open-next/
/.wrangler/
.dev.vars
cloudflare-env.d.ts
