{
  "name": "@nodetool-ai/marketing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "opennextjs-cloudflare build",
    "start": "next start --port 3001",
    "lint": "next lint",
    "og:screenshots": "next build && node scripts/generate-og-screenshots.mjs",
    "test:e2e": "playwright test",
    "seo:seed": "tsx seo/seed.ts",
    "seo:ingest": "node scripts/ingest-showcase.mjs",
    "seo:model-coverage": "node scripts/generate-model-coverage.mjs",
    "seo:model-watch": "node scripts/model-watch.mjs",
    "test:model-watch": "node --test scripts/__tests__/model-watch.test.mjs",
    "seo:catalog": "node scripts/generate-template-catalog.mjs",
    "seo:llms": "tsx scripts/generate-llms-txt.mjs",
    "seo:generate": "npm run seo:catalog && npm run seo:llms",
    "seo:check": "node scripts/generate-template-catalog.mjs --check && tsx scripts/generate-llms-txt.mjs --check",
    "gen:templates": "node scripts/generate-template-entries.mjs",
    "seo:typecheck": "tsc -p seo/tsconfig.json --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@fontsource/inter": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.1",
    "@tanstack/react-query": "^5.40.1",
    "@xyflow/react": "^12.4.3",
    "axios": "^1.6.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "formik": "^2.4.5",
    "framer-motion": "^12.23.12",
    "lodash": "^4.17.21",
    "lucide-react": "^0.341.0",
    "next": "^15.5.18",
    "openapi-fetch": "^0.7.1",
    "openapi-typescript": "^7.13.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^14.0.0",
    "wavesurfer.js": "^7.9.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/lodash": "^4.17.15",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/slate-html-serializer": "^0.6.8",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "@opennextjs/cloudflare": "^1.19.4",
    "wrangler": "^4.106.0"
  }
}
