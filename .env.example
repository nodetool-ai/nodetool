# Example environment variables for the NodeTool backend server.
# Copy to `.env` and adjust for your deployment. All values are optional unless
# noted; see docs/ and packages/config for the full set.

# ── Server ────────────────────────────────────────────────────────────────
# Host/port the websocket+HTTP server binds to.
HOST=0.0.0.0
PORT=7777
# Deployment environment: "development" | "production".
NODETOOL_ENV=development

# ── Database (choose one) ───────────────────────────────────────────────────
# SQLite file path (local/dev default), OR a PostgreSQL connection string.
DB_PATH=./nodetool.db
# DATABASE_URL=postgresql://user:pass@host:5432/nodetool

# ── Authentication (optional) ───────────────────────────────────────────────
# Auth is off by default (Local mode: loopback trusted, other sources rejected,
# no login screen). Set all three to enable Supabase login. The web UI reads
# these from the backend at runtime via GET /api/config — no frontend rebuild.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-key   # server-only, never sent to the browser
# SUPABASE_ANON_KEY=your-anon-key      # public key used by the login screen
# Optional OAuth redirect when served behind a domain/proxy (must be allow-listed
# in the Supabase project):
# AUTH_REDIRECT_URL=https://app.example.com/
#
# ============================================================================
# ⚠️  SECURITY: NODETOOL_TRUST_LOCAL_NETWORKS BYPASSES LOGIN  ⚠️
# ============================================================================
# Local mode only: source CIDRs trusted as admin user "1" WITHOUT any password.
# Behind Docker a published-port connection arrives from the bridge gateway
# (not loopback), so this must include that range or every API/WS call 401s.
# ANYONE who can reach the published port from a listed range gets full control
# of your data, secrets, and API keys. Scope it as tightly as possible.
# Ignored in Supabase mode (real logins take over).
#   NODETOOL_TRUST_LOCAL_NETWORKS=172.16.0.0/12   # ✅ Docker bridge (recommended)
#   NODETOOL_TRUST_LOCAL_NETWORKS=0.0.0.0/0       # 🚫 trusts EVERY source — LAN/VPN only, NEVER a public IP
# 🔒 Public / multi-user? Don't widen this — enable Supabase auth above instead.

# ── Secret encryption ───────────────────────────────────────────────────────
# 32-byte base64 key used to encrypt stored secrets. Generate with:
#   openssl rand -base64 32
# If unset, a key is generated and persisted next to the database — set this
# explicitly in production.
# SECRETS_MASTER_KEY=

# ── Storage ─────────────────────────────────────────────────────────────────
# "local" (default) or "s3". When "s3", configure the bucket/endpoint/region.
# NODETOOL_STORAGE_BACKEND=local
# ASSET_BUCKET=/workspace/assets
# S3_ENDPOINT_URL=
# S3_REGION=

# ── Model provider API keys (only what you use) ─────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# FAL_API_KEY=
# KIE_API_KEY=
# HF_TOKEN=
# OLLAMA_API_URL=http://localhost:11434

# ── Auth (optional, GitHub OAuth) ───────────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# ADMIN_USER_IDS=

# ── Observability (optional) ────────────────────────────────────────────────
# NODETOOL_LOG_LEVEL=info
# NODETOOL_TRACE_FILE=/tmp/nodetool-trace.jsonl
# NODETOOL_TRACE_STDOUT=pretty
