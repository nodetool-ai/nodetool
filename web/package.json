  "scripts": {
    "start": "vite --host 0.0.0.0 --port 3000 --strictPort --clearScreen false",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "build:debug": "NODE_OPTIONS=--max-old-space-size=16384 vite build --mode debug --sourcemap --minify false",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "tsc && eslint src && jest",
    "test": "jest --forceExit",
    "test:summary": "jest --reporters=\"summary\" --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "release": "ts-node release.ts",
    "openapi": "openapi-typescript http://127.0.0.1:7777/openapi.json -o ./src/api.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "fetch-comfy-schema": "node ../scripts/fetch-comfy-object-info.mjs",
    "upload-stock-images": "node scripts/upload-stock-images.js",
    "screenshots": "playwright test tests/benchmarks/screenshots.spec.ts --project=chromium",
    "screenshots:force": "FORCE_SCREENSHOTS=true playwright test tests/benchmarks/screenshots.spec.ts --project=chromium"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
