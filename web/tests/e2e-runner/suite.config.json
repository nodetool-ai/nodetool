{
  "$comment": "Curated E2E workflow suite. Each entry references a workflow graph in the repo; prepareSuite.ts copies the graph into web/public/e2e-suite and writes manifest.json. Deterministic workflows run in CI without API keys (agent/LLM nodes fall back to a ScriptedProvider on the e2e-server). Mark workflows that need real external providers with requiresSecrets so they are skipped when keys are absent.",
  "workflows": [
    {
      "id": "hello_input_output",
      "name": "Hello Input → Output",
      "source": "cli-fixtures",
      "sourceFile": "examples/workflows/hello_input_output_cli.json",
      "params": { "text": "hello from e2e" },
      "expect": { "status": "completed", "minOutputs": 1, "outputContains": "hello from e2e" },
      "tags": ["control", "deterministic"]
    },
    {
      "id": "hello_reroute",
      "name": "Hello Reroute",
      "source": "cli-fixtures",
      "sourceFile": "examples/workflows/hello_reroute.json",
      "params": {},
      "expect": { "status": "completed" },
      "tags": ["control", "deterministic"]
    },
    {
      "id": "if_branch",
      "name": "If Branch",
      "source": "cli-fixtures",
      "sourceFile": "examples/workflows/if_branch_cli.json",
      "params": { "condition": true, "payload": { "kind": "demo", "value": 42 } },
      "expect": { "status": "completed", "minOutputs": 1 },
      "tags": ["control", "deterministic"]
    },
    {
      "id": "if_true_route",
      "name": "If True Route",
      "source": "cli-fixtures",
      "sourceFile": "examples/workflows/if_true_route.json",
      "params": {},
      "expect": { "status": "completed" },
      "tags": ["control", "deterministic"]
    },
    {
      "id": "import_csv_select",
      "name": "Import CSV → Select Columns",
      "source": "cli-fixtures",
      "sourceFile": "examples/workflows/import_csv_select_cli.json",
      "params": { "csv_data": "team,score,city\nA,10,NY\nB,5,SF", "columns": "team,score" },
      "expect": { "status": "completed", "minOutputs": 1 },
      "tags": ["data", "deterministic"]
    },
    {
      "id": "import_csv_aggregate",
      "name": "Import CSV → Aggregate",
      "source": "cli-fixtures",
      "sourceFile": "examples/workflows/import_csv_aggregate_cli.json",
      "params": { "csv_data": "team,score\nA,10\nA,20\nB,5", "columns": "team", "aggregation": "sum" },
      "expect": { "status": "completed", "minOutputs": 1 },
      "tags": ["data", "deterministic"]
    },
    {
      "id": "wait_node",
      "name": "Wait Node",
      "source": "cli-fixtures",
      "sourceFile": "examples/workflows/wait_node_cli.json",
      "params": { "input": { "message": "hello" }, "timeout_seconds": 0.02 },
      "expect": { "status": "completed" },
      "tags": ["control", "deterministic"]
    },
    {
      "id": "run_shell",
      "name": "Run Shell Command",
      "source": "cli-fixtures",
      "sourceFile": "examples/workflows/run_shell_cli.json",
      "params": { "command": "echo hello-from-e2e" },
      "expect": { "status": "completed", "minOutputs": 1 },
      "tags": ["code", "deterministic"]
    },
    {
      "id": "agent_openai_basic",
      "name": "Agent (OpenAI) Basic",
      "source": "cli-fixtures",
      "sourceFile": "examples/workflows/agent_openai_basic_cli.json",
      "params": {
        "system": "You are a concise assistant.",
        "prompt": "Write one sentence about NodeTool workflows.",
        "model": { "provider": "openai", "id": "gpt-4o", "name": "GPT-4o" }
      },
      "expect": { "status": "completed" },
      "tags": ["agent", "llm"]
    }
  ]
