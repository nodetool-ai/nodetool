{
  "slug": "image-enhance",
  "name": "Image Enhance",
  "description": "Improve image quality with basic enhancement tools like sharpening, contrast and color adjustment",
  "image": "/app-preview/img/image-enhance.jpg",
  "app_doc": {
    "version": 2,
    "data": {
      "root": {
        "props": {
          "title": "Image Enhance"
        }
      },
      "content": [
        {
          "type": "Text",
          "props": {
            "id": "t-tagline",
            "text": "Sharper, brighter, cleaner — enhance any photo in one click."
          }
        },
        {
          "type": "Columns",
          "props": {
            "id": "cols-main",
            "gap": 24,
            "left": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-try",
                  "title": "Try it",
                  "content": [
                    {
                      "type": "WorkflowInput",
                      "props": {
                        "id": "in-image",
                        "binding": "image",
                        "events": []
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "id": "btn-run",
                        "label": "Enhance my photo",
                        "variant": "contained",
                        "color": "primary",
                        "events": [
                          {
                            "trigger": "click",
                            "kind": "run",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ],
            "right": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-results",
                  "title": "Results",
                  "content": [
                    {
                      "type": "Image",
                      "props": {
                        "id": "out-enhanced-image",
                        "binding": "enhanced_image",
                        "fit": "contain",
                        "height": 280,
                        "placeholder": "Your result appears here"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ],
      "zones": {}
    }
  },
  "values": {
    "enhanced_image": {
      "$demo": "image"
    }
  }
}
