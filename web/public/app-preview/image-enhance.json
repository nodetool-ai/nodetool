{
  "slug": "image-enhance",
  "name": "Image Enhance",
  "description": "A live photo editor: five GPU filters chained into one pipeline, each exposing a numeric property the app binds to a slider. Drag Denoise, Brightness, Contrast, Saturation, and Sharpen and the preview updates in place — the filters run in-browser, so there is no model, no API key, and no per-run cost.",
  "featured": true,
  "image": "/app-preview/img/image-enhance.jpg",
  "app_doc": {
    "version": 2,
    "data": {
      "root": {
        "props": {
          "title": "Image Enhance"
        }
      },
      "content": [
        {
          "type": "Text",
          "props": {
            "id": "t-tagline",
            "text": "A live photo editor: drag Denoise, Brightness, Contrast, Saturation, and Sharpen — the preview re-renders on release."
          }
        },
        {
          "type": "Columns",
          "props": {
            "id": "cols-main",
            "gap": 24,
            "left": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-try",
                  "title": "Try it",
                  "content": [
                    {
                      "type": "WorkflowInput",
                      "props": {
                        "id": "in-image",
                        "binding": "image",
                        "events": []
                      }
                    },
                    {
                      "type": "Slider",
                      "props": {
                        "id": "slider-denoise-node-radius",
                        "binding": "node:denoise-node#radius",
                        "label": "Denoise",
                        "min": 0,
                        "max": 16,
                        "step": 0.5,
                        "events": [
                          {
                            "trigger": "change",
                            "kind": "run",
                            "pace": "release",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    },
                    {
                      "type": "Slider",
                      "props": {
                        "id": "slider-tone-node-brightness",
                        "binding": "node:tone-node#brightness",
                        "label": "Brightness",
                        "min": -1,
                        "max": 1,
                        "step": 0.05,
                        "events": [
                          {
                            "trigger": "change",
                            "kind": "run",
                            "pace": "release",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    },
                    {
                      "type": "Slider",
                      "props": {
                        "id": "slider-tone-node-contrast",
                        "binding": "node:tone-node#contrast",
                        "label": "Contrast",
                        "min": 0,
                        "max": 4,
                        "step": 0.05,
                        "events": [
                          {
                            "trigger": "change",
                            "kind": "run",
                            "pace": "release",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    },
                    {
                      "type": "Slider",
                      "props": {
                        "id": "slider-color-node-saturation",
                        "binding": "node:color-node#saturation",
                        "label": "Saturation",
                        "min": 0,
                        "max": 4,
                        "step": 0.05,
                        "events": [
                          {
                            "trigger": "change",
                            "kind": "run",
                            "pace": "release",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    },
                    {
                      "type": "Slider",
                      "props": {
                        "id": "slider-sharpen-node-amount",
                        "binding": "node:sharpen-node#amount",
                        "label": "Sharpen",
                        "min": 0,
                        "max": 4,
                        "step": 0.05,
                        "events": [
                          {
                            "trigger": "change",
                            "kind": "run",
                            "pace": "release",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "id": "btn-run",
                        "label": "Enhance my photo",
                        "variant": "contained",
                        "color": "primary",
                        "events": [
                          {
                            "trigger": "click",
                            "kind": "run",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ],
            "right": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-results",
                  "title": "Results",
                  "content": [
                    {
                      "type": "Progress",
                      "props": {
                        "id": "progress-run",
                        "label": "Running the filter chain…",
                        "binding": ""
                      }
                    },
                    {
                      "type": "Image",
                      "props": {
                        "id": "out-enhanced-image",
                        "binding": "enhanced_image",
                        "fit": "contain",
                        "height": 280,
                        "placeholder": "Your result appears here"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ],
      "zones": {}
    }
  },
  "values": {
    "node:denoise-node#radius": 0,
    "node:tone-node#brightness": 0.05,
    "node:tone-node#contrast": 1.15,
    "node:color-node#saturation": 1.2,
    "node:sharpen-node#amount": 1,
    "enhanced_image": {
      "$demo": "image"
    }
  }
}
