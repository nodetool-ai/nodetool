                        "events": [
                          {
                            "trigger": "change",
                            "kind": "run",
                            "pace": "release",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "id": "btn-run",
