{
  "slug": "photo-enhancement-suite",
  "name": "Photo Enhancement Suite",
  "description": "Batch enhance photos with AI-powered improvements including color correction and upscaling.",
  "image": "/app-preview/img/photo-enhancement-suite.jpg",
  "app_doc": {
    "version": 2,
    "data": {
      "root": {
        "props": {
          "title": "Photo Enhancement Suite"
        }
      },
      "content": [
        {
          "type": "Text",
          "props": {
            "id": "t-tagline",
            "text": "Batch-enhance a whole folder of photos — color, brightness, upscaling."
          }
        },
        {
          "type": "Columns",
          "props": {
            "id": "cols-main",
            "gap": 24,
            "left": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-try",
                  "title": "Try it",
                  "content": [
                    {
                      "type": "WorkflowInput",
                      "props": {
                        "id": "in-image-folder",
                        "binding": "image_folder",
                        "events": []
                      }
                    },
                    {
                      "type": "WorkflowInput",
                      "props": {
                        "id": "in-brightness-adjust",
                        "binding": "brightness_adjust",
                        "events": []
                      }
                    },
                    {
                      "type": "WorkflowInput",
                      "props": {
                        "id": "in-color-boost",
                        "binding": "color_boost",
                        "events": []
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "id": "btn-run",
                        "label": "Enhance my photos",
                        "variant": "contained",
                        "color": "primary",
                        "events": [
                          {
                            "trigger": "click",
                            "kind": "run",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ],
            "right": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-results",
                  "title": "Results",
                  "content": [
                    {
                      "type": "Heading",
                      "props": {
                        "id": "lbl-enhanced-photos",
                        "text": "Enhanced",
                        "level": "3"
                      }
                    },
                    {
                      "type": "Image",
                      "props": {
                        "id": "out-enhanced-photos",
                        "binding": "enhanced_photos",
                        "fit": "contain",
                        "height": 280,
                        "placeholder": "Your result appears here"
                      }
                    },
                    {
                      "type": "Heading",
                      "props": {
                        "id": "lbl-upscaled-photos",
                        "text": "Upscaled",
                        "level": "3"
                      }
                    },
                    {
                      "type": "Image",
                      "props": {
                        "id": "out-upscaled-photos",
                        "binding": "upscaled_photos",
                        "fit": "contain",
                        "height": 280,
                        "placeholder": "Your result appears here"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ],
      "zones": {}
    }
  },
  "values": {
    "brightness_adjust": 1.05,
    "color_boost": 1.2,
    "enhanced_photos": {
      "$demo": "image"
    },
    "upscaled_photos": {
      "$demo": "image"
    }
  }
}
