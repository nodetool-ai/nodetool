{
  "slug": "data-generator",
  "name": "Data Generator",
  "description": "Turn a one-line topic into a structured dataset — define the columns once, get validated rows back instead of paragraphs of prose.",
  "featured": false,
  "image": "/app-preview/img/data-generator.jpg",
  "app_doc": {
    "version": 2,
    "data": {
      "root": {
        "props": {
          "title": "Data Generator"
        }
      },
      "content": [
