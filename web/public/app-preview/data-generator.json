          "type": "Text",
          "props": {
            "id": "t-tagline",
            "text": "Describe the dataset you need — an agent generates it, structured and ready."
          }
        },
        {
          "type": "Columns",
          "props": {
            "id": "cols-main",
            "gap": 24,
            "left": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-try",
                  "title": "Try it",
                  "content": [
                    {
                      "type": "WorkflowInput",
                      "props": {
                        "id": "in-topic",
                        "binding": "topic",
                        "events": []
                      }
                    },
                    {
                      "type": "WorkflowInput",
                      "props": {
                        "id": "in-row-count",
                        "binding": "row_count",
                        "events": []
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "id": "btn-run",
                        "label": "Generate data",
                        "variant": "contained",
                        "color": "primary",
                        "events": [
                          {
                            "trigger": "click",
                            "kind": "run",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ],
            "right": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-results",
                  "title": "Results",
                  "content": [
                    {
                      "type": "Progress",
                      "props": {
                        "id": "progress-run",
                        "label": "Generating rows…",
                        "binding": ""
                      }
                    },
                    {
                      "type": "Json",
                      "props": {
                        "id": "out-generated-data",
                        "binding": "generated_data"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ],
      "zones": {}
    }
  },
