{
  "slug": "story-to-video-generator",
  "name": "Story to Video Generator",
  "description": "Transform story ideas into cinematic AI-generated videos. An agent crafts detailed visual prompts optimized for video generation, then creates the video using Gemini Veo.",
  "image": "/app-preview/img/story-to-video-generator.jpg",
  "app_doc": {
    "version": 2,
    "data": {
      "root": {
        "props": {
          "title": "Story to Video Generator"
        }
      },
      "content": [
        {
          "type": "Text",
          "props": {
            "id": "t-tagline",
            "text": "Type a story idea — watch it become a cinematic AI-generated video."
          }
        },
        {
          "type": "Columns",
          "props": {
            "id": "cols-main",
            "gap": 24,
            "left": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-try",
                  "title": "Try it",
                  "content": [
                    {
                      "type": "WorkflowInput",
                      "props": {
                        "id": "in-story-theme",
                        "binding": "story_theme",
                        "events": []
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "id": "btn-run",
                        "label": "Generate my video",
                        "variant": "contained",
                        "color": "primary",
                        "events": [
                          {
                            "trigger": "click",
                            "kind": "run",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ],
            "right": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-results",
                  "title": "Results",
                  "content": [
                    {
                      "type": "Video",
                      "props": {
                        "id": "out-video",
                        "binding": "video",
                        "height": 320,
                        "placeholder": "Your video appears here"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ],
      "zones": {}
    }
  },
  "values": {
    "story_theme": "A lone astronaut discovering an ancient alien civilization on Mars",
    "video": {
      "$demo": "video"
    }
  }
}
