{
  "slug": "audio-to-image",
  "name": "Audio To Image",
  "description": "Transform spoken descriptions into images with this workflow. Record or upload audio, which is transcribed by Whisper and then visualized by Stable Diffusion. Perfect for quickly generating images from verbal ideas without typing.",
  "image": "/app-preview/img/audio-to-image.jpg",
  "app_doc": {
    "version": 2,
    "data": {
      "root": {
        "props": {
          "title": "Audio To Image"
        }
      },
      "content": [
        {
          "type": "Text",
          "props": {
            "id": "t-tagline",
            "text": "Describe a scene out loud — get it back as a picture."
          }
        },
        {
          "type": "Columns",
          "props": {
            "id": "cols-main",
            "gap": 24,
            "left": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-try",
                  "title": "Try it",
                  "content": [
                    {
                      "type": "WorkflowInput",
                      "props": {
                        "id": "in-description",
                        "binding": "description",
                        "events": []
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "id": "btn-run",
                        "label": "Turn my voice into art",
                        "variant": "contained",
                        "color": "primary",
                        "events": [
                          {
                            "trigger": "click",
                            "kind": "run",
                            "key": "",
                            "value": ""
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ],
            "right": [
              {
                "type": "Container",
                "props": {
                  "id": "panel-results",
                  "title": "Results",
                  "content": [
                    {
                      "type": "Image",
                      "props": {
                        "id": "out-image",
                        "binding": "image",
                        "fit": "contain",
                        "height": 280,
                        "placeholder": "Your result appears here"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ],
      "zones": {}
    }
  },
  "values": {
    "image": {
      "$demo": "image"
    }
  }
}
