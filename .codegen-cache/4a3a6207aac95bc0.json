            ],
            "title": "Duration",
            "type": "number",
            "description": "Duration of the generated audio in seconds"
          },
          "rtf": {
            "examples": [
              0.53
            ],
            "title": "Rtf",
            "type": "number",
            "description": "Real-time factor (generation_time / audio_duration). Lower is better."
          },
          "sample_rate": {
            "examples": [
              24000
            ],
            "title": "Sample Rate",
            "type": "integer",
            "description": "Sample rate of the generated audio"
