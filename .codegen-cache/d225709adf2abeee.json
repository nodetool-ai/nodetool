          "content_type",
          "file_name",
          "file_size",
          "duration",
          "bitrate",
          "codec",
          "container",
          "fps",
          "frame_count",
          "timebase",
          "resolution",
          "format",
          "audio",
          "start_frame_url",
          "end_frame_url"
