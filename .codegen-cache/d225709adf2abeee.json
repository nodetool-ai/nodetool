            "title": "File Name"
          },
          "sample_rate": {
            "description": "Audio sample rate in Hz",
            "type": "integer",
            "title": "Sample Rate"
          },
          "content_type": {
            "description": "MIME type of the media file",
            "type": "string",
            "title": "Content Type"
          },
          "container": {
            "description": "Container format of the media file (e.g., 'mp4', 'mov')",
            "type": "string",
            "title": "Container"
          },
          "channels": {
            "description": "Number of audio channels",
            "type": "integer",
            "title": "Channels"
          }
