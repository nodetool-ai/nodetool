          },
          "spill_suppression_strength": {
            "anyOf": [
              {
                "minimum": 0,
                "maximum": 1,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Spill Suppression Strength",
            "description": "Increase the value if green spots remain in the video, decrease if color changes are noticed on the extracted subject.",
            "default": 0.8
          }
        },
