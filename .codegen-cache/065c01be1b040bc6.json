    "schemas": {
      "QueueStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "IN_QUEUE",
              "IN_PROGRESS",
              "COMPLETED"
            ]
          },
          "request_id": {
            "type": "string",
            "description": "The request id."
          },
          "response_url": {
            "type": "string",
            "description": "The response url."
          },
          "status_url": {
            "type": "string",
            "description": "The status url."
          },
          "cancel_url": {
            "type": "string",
            "description": "The cancel url."
          },
          "logs": {
            "type": "object",
            "description": "The logs.",
            "additionalProperties": true
          },
          "metrics": {
            "type": "object",
            "description": "The metrics.",
            "additionalProperties": true
          },
          "queue_position": {
            "type": "integer",
            "description": "The queue position."
          }
        },
        "required": [
          "status",
          "request_id"
        ]
      },
      "MeshyV6PreviewTextTo3dInput": {
        "title": "TextTo3DInput",
        "type": "object",
        "properties": {
          "enable_pbr": {
            "title": "Enable Pbr",
            "type": "boolean",
            "description": "Generate PBR Maps (metallic, roughness, normal) in addition to base color. Should be false for sculpture style.",
            "default": false
          },
          "prompt": {
            "examples": [
              "A rustic, antique wooden treasure chest with a curved, domed lid, constructed from weathered, dark brown planks exhibiting prominent wood grain and subtle distress. It's heavily reinforced with broad, dark grey, oxidized metal bands secured by numerous circular rivets. Ornate, dark iron decorative elements featuring swirling foliate patterns and dragon motifs adorn the corners and lid. A prominent, circular, intricately carved metal lock plate with a central keyhole dominates the front, flanked by two large, dark metallic pull rings."
            ],
            "maxLength": 600,
            "type": "string",
            "title": "Prompt",
            "description": "Describe what kind of object the 3D model is. Maximum 600 characters."
          },
          "art_style": {
            "enum": [
              "realistic",
              "sculpture"
            ],
            "title": "Art Style",
            "type": "string",
            "description": "Desired art style of the object. Note: enable_pbr should be false for sculpture style.",
            "default": "realistic"
          },
          "target_polycount": {
            "minimum": 100,
            "title": "Target Polycount",
            "type": "integer",
            "maximum": 300000,
            "description": "Target number of polygons in the generated model",
            "default": 30000
          },
          "enable_rigging": {
            "title": "Enable Rigging",
            "type": "boolean",
            "description": "Automatically rig the generated model as a humanoid character. Includes basic walking and running animations. Best results with humanoid characters that have clearly defined limbs.",
            "default": false
          },
          "animation_action_id": {
            "examples": [
              1001
            ],
            "title": "Animation Action Id",
            "type": "integer",
            "description": "Animation preset ID from Meshy's library (500+ presets). Only used when enable_animation is true. See https://docs.meshy.ai/en/api/animation-library for available action IDs.",
            "default": 1001
          },
          "is_a_t_pose": {
            "title": "Is A T Pose",
            "type": "boolean",
            "description": "Deprecated: use pose_mode instead. When true, generates a T-pose model.",
            "deprecated": true,
            "default": false
          },
          "mode": {
            "enum": [
              "preview",
              "full"
            ],
            "title": "Mode",
            "type": "string",
            "description": "Generation mode. 'preview' returns untextured geometry only, 'full' returns textured model (preview + refine).",
            "default": "full"
          },
          "enable_safety_checker": {
            "title": "Enable Safety Checker",
            "type": "boolean",
            "description": "If set to true, input data will be checked for safety before processing.",
            "default": true
          },
          "symmetry_mode": {
            "enum": [
              "off",
              "auto",
              "on"
            ],
            "title": "Symmetry Mode",
            "type": "string",
            "description": "Controls symmetry behavior during model generation.",
            "default": "auto"
          },
          "should_remesh": {
            "title": "Should Remesh",
            "type": "boolean",
            "description": "Whether to enable the remesh phase. When false, returns unprocessed triangular mesh.",
            "default": true
          },
          "topology": {
            "enum": [
              "quad",
              "triangle"
            ],
            "title": "Topology",
            "type": "string",
            "description": "Specify the topology of the generated model. Quad for smooth surfaces, Triangle for detailed geometry.",
            "default": "triangle"
          },
          "pose_mode": {
            "enum": [
              "a-pose",
              "t-pose",
              ""
            ],
            "title": "Pose Mode",
            "type": "string",
            "description": "Pose mode for the generated model. 'a-pose' generates an A-pose, 't-pose' generates a T-pose, empty string for no specific pose.",
            "default": ""
          },
          "texture_image_url": {
            "anyOf": [
              {
                "type": "string",
                "_fal_ui_field": "image",
                "ui": {
                  "field": "image"
                }
              },
              {
                "type": "null"
              }
            ],
            "title": "Texture Image Url",
            "max_pixels": 178956970,
            "description": "2D image to guide the texturing process (only used in 'full' mode)",
            "max_file_size": 20971520
          },
          "enable_animation": {
            "title": "Enable Animation",
            "type": "boolean",
            "description": "Apply an animation preset to the rigged model. Requires enable_rigging to be true.",
            "default": false
          },
          "enable_prompt_expansion": {
            "title": "Enable Prompt Expansion",
            "type": "boolean",
            "description": "Whether to enable prompt expansion. This will use a large language model to expand the prompt with additional details while maintaining the original meaning.",
            "default": false
          },
          "seed": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Seed",
            "description": "Seed for reproducible results. Same prompt and seed usually generate the same result."
          },
          "texture_prompt": {
            "anyOf": [
              {
                "maxLength": 600,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Texture Prompt",
            "description": "Additional text prompt to guide the texturing process (only used in 'full' mode)"
          },
          "rigging_height_meters": {
            "title": "Rigging Height Meters",
            "type": "number",
            "description": "Approximate height of the character in meters. Only used when enable_rigging is true.",
            "exclusiveMinimum": 0,
            "default": 1.7
          }
        },
        "x-fal-order-properties": [
          "prompt",
          "mode",
          "art_style",
          "seed",
          "topology",
          "target_polycount",
          "should_remesh",
          "symmetry_mode",
          "enable_pbr",
          "is_a_t_pose",
          "pose_mode",
