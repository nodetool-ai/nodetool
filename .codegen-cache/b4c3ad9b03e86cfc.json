            "title": "Audio Url"
          },
          "mask_start": {
            "description": "The start point of the audio mask",
            "type": "integer",
            "examples": [
              15
            ],
            "title": "Mask Start",
            "minimum": 0,
            "maximum": 190,
            "default": 30
          }
        },
        "title": "InpaintInput",
        "required": [
          "prompt",
          "audio_url"
        ]
