            "title": "File Name"
          },
          "content_type": {
            "examples": [
              "image/png"
            ],
            "description": "The mime type of the file.",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content Type"
          },
          "url": {
            "description": "The URL where the file can be downloaded from.",
            "type": "string",
            "title": "Url"
          }
