      "ImageSize": {
        "title": "ImageSize",
        "type": "object",
        "properties": {
          "height": {
            "title": "Height",
            "type": "integer",
            "description": "The height of the generated image.",
            "maximum": 14142,
            "exclusiveMinimum": 0,
            "default": 512
