{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/wan/v2.2-14b/speech-to-video",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/wan/v2.2-14b/speech-to-video queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/wan/v2.2-14b/speech-to-video",
