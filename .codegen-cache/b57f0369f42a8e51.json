{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/meshy/v5/multi-image-to-3d",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/meshy/v5/multi-image-to-3d queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/meshy/v5/multi-image-to-3d",
      "category": "image-to-3d",
      "thumbnailUrl": "https://v3.fal.media/files/penguin/wLQpmudI-iiOD545isnQ0_b7878036846e4f72b23e29f55c97016e.jpg",
      "playgroundUrl": "https://fal.ai/models/fal-ai/meshy/v5/multi-image-to-3d",
      "documentationUrl": "https://fal.ai/models/fal-ai/meshy/v5/multi-image-to-3d/api"
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Fal Key"
      }
    },
    "schemas": {
      "QueueStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "IN_QUEUE",
              "IN_PROGRESS",
              "COMPLETED"
            ]
          },
          "request_id": {
            "type": "string",
            "description": "The request id."
          },
          "response_url": {
            "type": "string",
            "description": "The response url."
          },
          "status_url": {
            "type": "string",
            "description": "The status url."
          },
          "cancel_url": {
            "type": "string",
            "description": "The cancel url."
          },
          "logs": {
            "type": "object",
            "description": "The logs.",
            "additionalProperties": true
          },
          "metrics": {
            "type": "object",
            "description": "The metrics.",
            "additionalProperties": true
          },
          "queue_position": {
            "type": "integer",
            "description": "The queue position."
          }
        },
        "required": [
          "status",
          "request_id"
        ]
      },
      "MeshyV5MultiImageTo3dInput": {
        "title": "MultiImageTo3DInput",
        "type": "object",
        "properties": {
          "enable_pbr": {
            "title": "Enable Pbr",
            "type": "boolean",
            "description": "Generate PBR Maps (metallic, roughness, normal) in addition to base color. Requires should_texture to be true.",
            "default": false
          },
          "texture_prompt": {
            "anyOf": [
              {
                "maxLength": 600,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Texture Prompt",
            "description": "Text prompt to guide the texturing process. Requires should_texture to be true."
          },
          "target_polycount": {
            "minimum": 100,
            "title": "Target Polycount",
            "type": "integer",
            "maximum": 300000,
            "description": "Target number of polygons in the generated model",
            "default": 30000
          },
          "enable_rigging": {
            "title": "Enable Rigging",
            "type": "boolean",
            "description": "Automatically rig the generated model as a humanoid character. Includes basic walking and running animations. Best results with humanoid characters that have clearly defined limbs.",
            "default": false
          },
          "animation_action_id": {
            "examples": [
              1001
            ],
            "title": "Animation Action Id",
            "type": "integer",
            "description": "Animation preset ID from Meshy's library (500+ presets). Only used when enable_animation is true. See https://docs.meshy.ai/en/api/animation-library for available action IDs.",
            "default": 1001
          },
          "enable_safety_checker": {
            "title": "Enable Safety Checker",
            "type": "boolean",
            "description": "If set to true, input data will be checked for safety before processing.",
            "default": true
          },
          "symmetry_mode": {
            "enum": [
              "off",
              "auto",
              "on"
            ],
            "title": "Symmetry Mode",
            "type": "string",
            "description": "Controls symmetry behavior during model generation.",
            "default": "auto"
          },
          "image_urls": {
            "description": "1 to 4 images for 3D model creation. All images should depict the same object from different angles. Supports .jpg, .jpeg, .png formats, and AVIF/HEIF which will be automatically converted. If more than 4 images are provided, only the first 4 will be used.",
            "type": "array",
            "max_pixels": 178956970,
            "items": {
              "type": "string",
              "_fal_ui_field": "image"
            },
            "max_file_size": 20971520,
            "examples": [
              [
                "https://v3b.fal.media/files/b/kangaroo/cPyD3-por0XI7jDa9F9vP_image%20(3).png",
                "https://v3b.fal.media/files/b/elephant/9sd5JWAOJBcR7G3NMjPVs_image%20(2).png",
                "https://v3b.fal.media/files/b/tiger/TP4sTzPATX_w1Tn4m6kYM_image%20(1).png"
              ]
            ],
            "title": "Image Urls"
          },
          "should_remesh": {
            "title": "Should Remesh",
            "type": "boolean",
            "description": "Whether to enable the remesh phase. When false, returns triangular mesh ignoring topology and target_polycount.",
            "default": true
          },
          "should_texture": {
            "title": "Should Texture",
            "type": "boolean",
            "description": "Whether to generate textures. False provides mesh without textures for 5 credits, True adds texture generation for additional 10 credits.",
            "default": true
          },
          "topology": {
            "enum": [
              "quad",
              "triangle"
            ],
            "title": "Topology",
            "type": "string",
            "description": "Specify the topology of the generated model. Quad for smooth surfaces, Triangle for detailed geometry.",
            "default": "triangle"
          },
          "pose_mode": {
            "enum": [
              "a-pose",
              "t-pose",
              ""
            ],
            "title": "Pose Mode",
            "type": "string",
            "description": "Pose mode for the generated model. 'a-pose' generates an A-pose, 't-pose' generates a T-pose, empty string for no specific pose.",
            "default": ""
          },
          "texture_image_url": {
            "anyOf": [
              {
                "type": "string",
                "_fal_ui_field": "image",
                "ui": {
                  "field": "image"
                }
              },
              {
                "type": "null"
              }
            ],
            "title": "Texture Image Url",
            "max_pixels": 178956970,
            "description": "2D image to guide the texturing process. Requires should_texture to be true.",
            "max_file_size": 20971520
          },
          "enable_animation": {
            "title": "Enable Animation",
            "type": "boolean",
            "description": "Apply an animation preset to the rigged model. Requires enable_rigging to be true.",
            "default": false
          },
          "is_a_t_pose": {
            "title": "Is A T Pose",
            "type": "boolean",
            "description": "Deprecated: use pose_mode instead. When true, generates a T-pose model.",
            "deprecated": true,
            "default": false
          },
          "rigging_height_meters": {
            "title": "Rigging Height Meters",
            "type": "number",
            "description": "Approximate height of the character in meters. Only used when enable_rigging is true.",
            "exclusiveMinimum": 0,
            "default": 1.7
          }
        },
        "x-fal-order-properties": [
          "image_urls",
          "topology",
          "target_polycount",
          "symmetry_mode",
          "should_remesh",
          "should_texture",
          "enable_pbr",
          "is_a_t_pose",
          "pose_mode",
          "texture_prompt",
          "texture_image_url",
          "enable_rigging",
          "rigging_height_meters",
          "enable_animation",
          "animation_action_id",
          "enable_safety_checker"
        ],
        "description": "Input for Multi-Image to 3D conversion",
        "required": [
          "image_urls"
        ]
      },
