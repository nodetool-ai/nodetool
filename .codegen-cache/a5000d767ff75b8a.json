            "type": "number",
            "maximum": 20,
            "description": "The strength of Classifier Free Guidance.",
            "default": 4.5
          },
          "seed": {
            "minimum": 0,
            "title": "Seed",
            "type": "integer",
            "description": "The seed for the random number generator",
