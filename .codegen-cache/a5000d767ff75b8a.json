          },
          "mask_away_clip": {
            "title": "Mask Away Clip",
            "type": "boolean",
            "description": "Whether to mask away the clip.",
            "default": false
          },
          "negative_prompt": {
            "title": "Negative Prompt",
            "type": "string",
            "description": "The negative prompt to generate the audio for.",
            "default": ""
