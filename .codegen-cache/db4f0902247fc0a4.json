{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/xtts",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/xtts queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/xtts",
      "playgroundUrl": "https://fal.ai/models/fal-ai/xtts",
      "documentationUrl": "https://fal.ai/models/fal-ai/xtts/api"
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Fal Key"
      }
    },
    "schemas": {
      "QueueStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "IN_QUEUE",
              "IN_PROGRESS",
              "COMPLETED"
            ]
          },
          "request_id": {
            "type": "string",
            "description": "The request id."
          },
          "response_url": {
            "type": "string",
            "description": "The response url."
          },
          "status_url": {
            "type": "string",
            "description": "The status url."
          },
          "cancel_url": {
            "type": "string",
            "description": "The cancel url."
          },
          "logs": {
            "type": "object",
            "description": "The logs.",
            "additionalProperties": true
          },
          "metrics": {
            "type": "object",
            "description": "The metrics.",
            "additionalProperties": true
          },
          "queue_position": {
            "type": "integer",
            "description": "The queue position."
          }
        },
        "required": [
          "status",
          "request_id"
        ]
      },
      "XttsInput": {
        "title": "XTTSInput",
        "type": "object",
        "properties": {
          "prompt": {
            "examples": [
              "How are you doing friends?"
            ],
            "title": "Prompt",
            "type": "string",
            "description": "The text prompt you would like to convert to speech."
          },
          "repetition_penalty": {
            "minimum": 0,
            "maximum": 10,
            "type": "number",
            "title": "Repetition Penalty",
            "description": "The repetition penalty to use for generation. Defaults to 5.0.",
            "default": 5
          },
          "language": {
            "enum": [
              "English",
              "Spanish",
              "French",
              "German",
              "Italian",
              "Portuguese",
              "Polish",
              "Turkish",
              "Russian",
              "Dutch",
              "Czech",
              "Arabic",
              "Chinese",
              "Japanese",
              "Hungarian",
              "Korean",
              "Hindi"
            ],
            "title": "Language",
            "type": "string",
            "description": "The language to use for generation. Defaults to English.",
            "default": "English"
          },
          "gpt_cond_len": {
            "minimum": 0,
            "maximum": 100,
            "type": "integer",
            "title": "Gpt Cond Len",
            "description": "The length of the GPT conditioning. Defaults to 30.",
            "default": 30
          },
          "gpt_cond_chunk_len": {
            "minimum": 0,
            "maximum": 100,
            "type": "integer",
            "title": "Gpt Cond Chunk Len",
            "description": "The length of the GPT conditioning chunks. Defaults to 4.",
            "default": 4
          },
          "audio_url": {
            "examples": [
              "https://storage.googleapis.com/falserverless/model_tests/whisper/dinner_conversation.mp3"
            ],
            "title": "Audio Url",
            "type": "string",
            "description": "URL of the voice file to match"
          },
          "temperature": {
            "minimum": 0,
            "maximum": 10,
            "type": "number",
            "title": "Temperature",
            "description": "The temperature to use for generation. Higher is more creative. Defaults to 0.75.",
            "default": 0.75
          },
          "sample_rate": {
            "minimum": 0,
            "maximum": 48000,
            "type": "integer",
            "title": "Sample Rate",
            "description": "The sample rate of the audio. Defaults to 24000.",
            "default": 24000
          },
          "max_ref_length": {
            "minimum": 0,
            "maximum": 100,
            "type": "integer",
            "title": "Max Ref Length",
            "description": "The maximum length of the reference. Defaults to 60.",
            "default": 60
          }
        },
        "x-fal-order-properties": [
          "prompt",
          "audio_url",
          "repetition_penalty",
          "language",
          "temperature",
          "gpt_cond_len",
          "gpt_cond_chunk_len",
          "max_ref_length",
          "sample_rate"
        ],
        "required": [
          "prompt",
          "audio_url"
        ]
      },
      "XttsOutput": {
        "title": "XTTSOutput",
        "type": "object",
        "properties": {
          "audio_file": {
            "title": "Audio File",
            "description": "The generated image file info.",
            "allOf": [
              {
                "$ref": "#/components/schemas/Image"
              }
            ]
          }
        },
        "x-fal-order-properties": [
          "audio_file"
        ],
        "required": [
          "audio_file"
        ]
      },
      "Image": {
        "title": "Image",
        "type": "object",
        "properties": {
          "file_size": {
            "examples": [
              4404019
            ],
            "title": "File Size",
            "type": "integer",
            "description": "The size of the file in bytes."
          },
          "height": {
            "examples": [
              1024
            ],
            "title": "Height",
            "type": "integer",
            "description": "The height of the image in pixels."
          },
          "file_name": {
            "examples": [
              "z9RV14K95DvU.png"
            ],
            "title": "File Name",
            "type": "string",
            "description": "The name of the file. It will be auto-generated if not provided."
          },
          "content_type": {
            "examples": [
              "image/png"
            ],
            "title": "Content Type",
            "type": "string",
            "description": "The mime type of the file."
          },
          "url": {
            "examples": [
              "https://url.to/generated/file/z9RV14K95DvU.png"
            ],
            "title": "Url",
            "type": "string",
            "description": "The URL where the file can be downloaded from."
          },
          "width": {
            "examples": [
              1024
            ],
            "title": "Width",
            "type": "integer",
            "description": "The width of the image in pixels."
          }
        },
        "description": "Represents an image file.",
        "x-fal-order-properties": [
          "url",
          "content_type",
          "file_name",
          "file_size",
          "width",
          "height"
        ],
        "required": [
          "url",
          "content_type",
          "file_name",
          "file_size"
        ]
      }
    }
  },
  "paths": {
    "/fal-ai/xtts/requests/{request_id}/status": {
      "get": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Request ID"
            }
          },
          {
            "name": "logs",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "description": "Whether to include logs (`1`) in the response or not (`0`)."
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueStatus"
                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/xtts/requests/{request_id}/cancel": {
      "put": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Request ID"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request was cancelled.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "description": "Whether the request was cancelled successfully."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/xtts": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/XttsInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The request status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueStatus"
                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/xtts/requests/{request_id}": {
      "get": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Request ID"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Result of the request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/XttsOutput"
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "https://queue.fal.run"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ]
}