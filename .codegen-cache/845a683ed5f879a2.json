          "loras",
          "resolution",
          "aspect_ratio",
          "seed",
          "num_frames",
          "first_pass_num_inference_steps",
          "second_pass_num_inference_steps",
          "second_pass_skip_initial_steps",
          "frame_rate",
          "expand_prompt",
