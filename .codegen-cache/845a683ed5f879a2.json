        "type": "object",
        "properties": {
          "video_url": {
            "title": "Video URL",
            "type": "string",
            "description": "URL of video to use as conditioning"
          },
          "start_frame_num": {
            "description": "Frame number of the video from which the conditioning starts. Must be a multiple of 8.",
