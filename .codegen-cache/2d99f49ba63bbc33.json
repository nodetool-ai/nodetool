            "title": "Prompt",
            "type": "string",
            "description": "The text prompt to guide video generation."
          },
          "resolution": {
            "enum": [
              "480p",
              "580p",
              "720p"
            ],
            "title": "Resolution",
            "type": "string",
            "examples": [
              "480p"
            ],
            "description": "Resolution of the generated video (480p, 580p, 720p).",
