        "description": "Fal Key"
      }
    },
    "schemas": {
      "QueueStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "IN_QUEUE",
              "IN_PROGRESS",
              "COMPLETED"
            ]
          },
          "request_id": {
            "type": "string",
            "description": "The request id."
          },
          "response_url": {
            "type": "string",
            "description": "The response url."
          },
          "status_url": {
            "type": "string",
            "description": "The status url."
          },
          "cancel_url": {
            "type": "string",
            "description": "The cancel url."
          },
          "logs": {
            "type": "object",
            "description": "The logs.",
            "additionalProperties": true
          },
          "metrics": {
            "type": "object",
            "description": "The metrics.",
            "additionalProperties": true
          },
          "queue_position": {
            "type": "integer",
            "description": "The queue position."
          }
        },
        "required": [
          "status",
          "request_id"
        ]
      },
      "SyncLipsyncReact1Input": {
        "x-fal-order-properties": [
          "video_url",
          "audio_url",
          "emotion",
          "model_mode",
          "lipsync_mode",
          "temperature"
        ],
        "type": "object",
        "properties": {
          "model_mode": {
            "enum": [
              "lips",
              "face",
              "head"
            ],
            "description": "Controls the edit region and movement scope for the model. Available options:\n- `lips`: Only lipsync using react-1 (minimal facial changes).\n- `face`: Lipsync + facial expressions without head movements.\n- `head`: Lipsync + facial expressions + natural talking head movements.",
            "type": "string",
            "title": "Model Mode",
            "default": "face"
          },
          "video_url": {
            "examples": [
              "https://storage.googleapis.com/falserverless/example_inputs/react_1/input.mp4"
            ],
            "description": "URL to the input video. Must be **15 seconds or shorter**.",
            "type": "string",
            "title": "Video Url"
          },
          "lipsync_mode": {
            "enum": [
              "cut_off",
              "loop",
              "bounce",
              "silence",
              "remap"
            ],
            "description": "Lipsync mode when audio and video durations are out of sync.",
            "type": "string",
            "title": "Lipsync Mode",
            "default": "bounce"
          },
          "audio_url": {
            "examples": [
              "https://storage.googleapis.com/falserverless/example_inputs/react_1/input.mp3"
            ],
            "description": "URL to the input audio. Must be **15 seconds or shorter**.",
            "type": "string",
            "title": "Audio Url"
          },
          "temperature": {
            "minimum": 0,
            "description": "Controls the expresiveness of the lipsync.",
            "type": "number",
            "title": "Temperature",
            "maximum": 1,
            "default": 0.5
          },
          "emotion": {
            "enum": [
              "happy",
              "angry",
              "sad",
              "neutral",
              "disgusted",
              "surprised"
            ],
            "description": "Emotion prompt for the generation. Currently supports single-word emotions only.",
            "type": "string",
            "title": "Emotion",
            "examples": [
              "neutral"
            ]
          }
        },
        "title": "React1Input",
        "required": [
          "video_url",
          "audio_url",
          "emotion"
        ]
      },
      "SyncLipsyncReact1Output": {
        "x-fal-order-properties": [
          "video"
        ],
        "type": "object",
        "properties": {
          "video": {
            "examples": [
              {
                "height": 1088,
                "duration": 7.041667,
                "url": "https://storage.googleapis.com/falserverless/example_outputs/react_1/output.mp4",
                "fps": 24,
                "width": 1920,
                "file_name": "output.mp4",
                "content_type": "video/mp4",
                "num_frames": 169
              }
            ],
            "description": "The generated video with synchronized lip and facial movements.",
            "$ref": "#/components/schemas/VideoFile"
          }
        },
        "title": "React1Output",
        "required": [
          "video"
        ]
      },
      "VideoFile": {
        "x-fal-order-properties": [
          "url",
          "content_type",
          "file_name",
