            "description": "The size of the file in bytes.",
            "title": "File Size",
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ]
          },
          "file_name": {
            "examples": [
              "z9RV14K95DvU.png"
