            "description": "The seed for the random number generator",
            "title": "Seed"
          },
          "negative_prompt": {
            "description": "A negative prompt to guide the model",
            "type": "string",
            "title": "Negative Prompt",
            "default": "ugly, bad, terrible"
          }
        },
        "title": "Pika22TextToVideoRequest",
        "x-fal-order-properties": [
          "prompt",
          "seed",
          "negative_prompt",
          "aspect_ratio",
          "resolution",
          "duration"
