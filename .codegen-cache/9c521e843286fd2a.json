        "description": "Output model for Pika 2.2 text-to-video generation",
        "type": "object",
        "properties": {
          "video": {
            "examples": [
              {
                "url": "https://storage.googleapis.com/falserverless/example_outputs/pika/pika_t2v_v22_output.mp4"
