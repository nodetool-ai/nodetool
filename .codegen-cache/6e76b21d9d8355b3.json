      "LumaDreamMachineRay2FlashModifyInput": {
        "title": "ModifyVideoRequest",
        "type": "object",
        "properties": {
          "prompt": {
            "anyOf": [
              {
                "maxLength": 5000,
                "minLength": 3,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Instruction for modifying the video",
            "title": "Prompt"
          },
