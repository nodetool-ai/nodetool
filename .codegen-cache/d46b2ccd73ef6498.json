              ]
            ],
            "title": "Images",
            "type": "array",
            "description": "The processed images with sharpen effect",
            "items": {
              "$ref": "#/components/schemas/Image"
            }
          }
        },
        "title": "SharpenOutput",
        "required": [
          "images"
        ]
      },
      "Image": {
        "x-fal-order-properties": [
          "url",
          "content_type",
          "file_name",
          "file_size",
          "width",
          "height"
        ],
        "type": "object",
        "description": "Represents an image file.",
        "title": "Image",
        "properties": {
          "height": {
            "anyOf": [
              {
                "type": "integer"
