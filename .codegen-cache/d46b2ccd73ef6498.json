      "PostProcessingSharpenInput": {
        "x-fal-order-properties": [
          "image_url",
          "sharpen_mode",
          "sharpen_radius",
          "sharpen_alpha",
          "noise_radius",
          "preserve_edges",
          "smart_sharpen_strength",
          "smart_sharpen_ratio",
          "cas_amount"
