          "avatar_id",
          "text"
        ],
        "required": [
          "avatar_id",
          "text"
        ]
      },
      "AvatarsTextToVideoOutput": {
        "title": "AvatarsAppOutput",
        "type": "object",
        "properties": {
          "video": {
            "examples": [
              {
                "content_type": "video/mp4",
