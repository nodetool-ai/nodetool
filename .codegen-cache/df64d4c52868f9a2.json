          "turbo_mode": {
            "title": "Turbo Mode",
            "type": "boolean",
            "description": "Enable turbo mode to use faster inference.",
            "default": true
          },
          "loras": {
            "title": "Loras",
            "type": "array",
            "description": "Optional additional LoRAs to merge (max 3).",
