              "$ref": "#/components/schemas/ImageFile"
            }
          },
          "seed": {
            "title": "Seed",
            "type": "integer",
            "description": "The seed for the inference."
          }
        },
        "x-fal-order-properties": [
          "images",
          "prompt",
          "seed"
        ],
        "description": "Unified output model for all ChronoEdit operations",
        "required": [
          "images",
          "prompt",
          "seed"
        ]
