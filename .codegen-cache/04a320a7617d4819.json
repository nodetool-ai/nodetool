  "info": {
    "title": "Queue OpenAPI for fal-ai/sora-2/video-to-video/remix",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/sora-2/video-to-video/remix queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/sora-2/video-to-video/remix",
