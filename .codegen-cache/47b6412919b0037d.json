{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/kandinsky5-pro/text-to-video",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/kandinsky5-pro/text-to-video queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/kandinsky5-pro/text-to-video",
