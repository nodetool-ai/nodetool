        "properties": {
          "height": {
            "examples": [
              1024
            ],
            "description": "The height of the image in pixels.",
            "type": "integer",
            "title": "Height"
          },
          "file_size": {
            "examples": [
              4404019
            ],
            "description": "The size of the file in bytes.",
            "type": "integer",
            "title": "File Size"
          },
