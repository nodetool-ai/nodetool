{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/hunyuan-image/v3/instruct/text-to-image",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/hunyuan-image/v3/instruct/text-to-image queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/hunyuan-image/v3/instruct/text-to-image",
