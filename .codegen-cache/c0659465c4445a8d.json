        },
        "x-fal-order-properties": [
          "path",
          "tokens"
        ],
        "required": [
          "path"
        ]
      },
      "LoraWeight": {
        "title": "LoraWeight",
        "type": "object",
        "properties": {
          "path": {
            "examples": [
              "https://civitai.com/api/download/models/135931",
