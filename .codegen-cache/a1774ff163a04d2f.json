            "type": "string",
            "title": "Prompt",
            "default": ""
          },
          "control_type": {
            "examples": [
              "ImagePrompt",
              "PyraCanny",
              "CPDS",
              "FaceSwap"
            ],
            "description": "The type of image control",
            "type": "string",
            "enum": [
