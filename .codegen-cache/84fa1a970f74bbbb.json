        "required": [
          "avatar_id",
          "audio_url"
        ]
      },
      "AvatarsAudioToVideoOutput": {
        "title": "AvatarsAppOutput",
        "type": "object",
        "properties": {
          "video": {
            "examples": [
              {
                "content_type": "video/mp4",
                "url": "https://v3.fal.media/files/panda/kt9d4vZ8Mfw_WzYnvr2Q0_tmp0ir4znsr.mp4"
