                  },
                  {
                    "y": 283,
                    "speed": 1,
                    "x": 481
                  },
                  {
                    "y": 263,
                    "speed": 1,
                    "x": 440
                  },
                  {
                    "y": 252,
                    "speed": 1,
                    "x": 385
                  },
                  {
                    "y": 252,
                    "speed": 1,
                    "x": 347
                  }
                ],
                [
                  {
                    "y": 262,
                    "speed": 1,
                    "x": 555
                  },
                  {
                    "y": 242,
                    "speed": 1,
                    "x": 505
                  },
                  {
                    "y": 243,
                    "speed": 1,
                    "x": 466
                  },
                  {
                    "y": 264,
                    "speed": 1,
                    "x": 440
                  },
                  {
                    "y": 287,
                    "speed": 1,
                    "x": 439
                  },
                  {
                    "y": 330,
                    "speed": 1,
                    "x": 471
                  },
                  {
                    "y": 345,
                    "speed": 1,
