                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/wan-fun-control/requests/{request_id}": {
      "get": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Request ID"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Result of the request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WanFunControlOutput"
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
