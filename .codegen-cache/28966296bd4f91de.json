          "image_url": {
            "examples": [
              "https://fal.media/files/rabbit/JlBgYUyQRS3zxiBu_B4fM.png",
              "https://fal.media/files/monkey/e6RtJf_ue0vyWzeiEmTby.png",
              "https://fal.media/files/monkey/A6HGsigx4mmvs-hJVoOZX.png"
