      "KlingV3ComboElementInput": {
        "x-fal-order-properties": [
          "frontal_image_url",
          "reference_image_urls",
          "video_url"
        ],
        "type": "object",
        "properties": {
          "video_url": {
            "anyOf": [
              {
                "x-fal": {
                  "min_fps": 24,
                  "max_fps": 60,
                  "max_file_size": 209715200,
                  "min_duration": 3,
                  "min_width": 720,
                  "timeout": 30,
                  "max_duration": 10.05,
                  "max_width": 2160,
                  "max_height": 2160,
                  "min_height": 720
                },
                "type": "string",
                "ui": {
                  "field": "video"
