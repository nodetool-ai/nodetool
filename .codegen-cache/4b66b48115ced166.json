            "minimum": 0,
            "maximum": 1,
            "type": "number",
            "title": "Dodge Burn Intensity",
            "description": "Dodge and burn intensity",
            "default": 0.5
          },
          "tint_mode": {
            "enum": [
              "sepia",
              "red",
              "green",
              "blue",
              "cyan",
              "magenta",
              "yellow",
              "purple",
              "orange",
              "warm",
              "cool",
              "lime",
              "navy",
              "vintage",
              "rose",
              "teal",
              "maroon",
              "peach",
              "lavender",
              "olive"
