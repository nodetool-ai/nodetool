          "image_url",
          "enable_grain",
          "grain_intensity",
          "grain_scale",
          "grain_style",
          "enable_color_correction",
          "temperature",
          "brightness",
          "contrast",
          "saturation",
          "gamma",
          "enable_chromatic",
          "red_shift",
          "red_direction",
          "green_shift",
