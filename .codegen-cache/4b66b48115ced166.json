            "minimum": 0,
            "maximum": 1,
            "title": "Grain Intensity",
            "multipleOf": 0.01,
            "default": 0.4
          },
          "vertex_y": {
            "minimum": 0,
            "maximum": 1,
            "type": "number",
            "title": "Vertex Y",
            "description": "Vertex Y position",
            "default": 0.5
          },
          "smart_sharpen_strength": {
            "minimum": 0,
            "maximum": 25,
            "type": "number",
            "title": "Smart Sharpen Strength",
