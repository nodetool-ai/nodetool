        "properties": {
          "blue_shift": {
            "minimum": -20,
            "maximum": 20,
            "type": "integer",
            "title": "Blue Shift",
            "description": "Blue channel shift amount",
            "default": 0
          },
          "enable_parabolize": {
            "title": "Enable Parabolize",
            "type": "boolean",
            "description": "Enable parabolize effect",
            "default": false
          },
          "green_direction": {
            "enum": [
              "horizontal",
              "vertical"
            ],
            "title": "Green Direction",
            "type": "string",
            "description": "Green channel shift direction",
            "default": "horizontal"
