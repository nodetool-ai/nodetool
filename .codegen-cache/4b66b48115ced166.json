          "enable_tint": {
            "title": "Enable Tint",
            "type": "boolean",
            "description": "Enable color tint effect",
            "default": false
          },
          "green_shift": {
            "minimum": -20,
            "maximum": 20,
            "type": "integer",
            "title": "Green Shift",
