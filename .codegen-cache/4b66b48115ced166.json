            "maximum": 10,
            "type": "number",
            "title": "Blur Sigma",
            "description": "Sigma for Gaussian blur",
            "default": 1
          },
          "desaturate_method": {
            "enum": [
              "luminance (Rec.709)",
              "luminance (Rec.601)",
              "average",
              "lightness"
