          "enable_vignette": {
            "title": "Enable Vignette",
            "type": "boolean",
            "description": "Enable vignette effect",
            "default": false
          },
          "blur_type": {
            "enum": [
              "gaussian",
              "kuwahara"
            ],
            "title": "Blur Type",
            "type": "string",
            "description": "Type of blur to apply",
            "default": "gaussian"
          },
          "red_shift": {
            "minimum": -20,
            "maximum": 20,
            "type": "integer",
            "title": "Red Shift",
            "description": "Red channel shift amount",
            "default": 0
          },
          "grain_style": {
            "enum": [
              "modern",
              "analog",
              "kodak",
              "fuji",
              "cinematic",
              "newspaper"
