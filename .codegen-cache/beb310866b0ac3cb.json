            "type": "array",
            "title": "Image Urls",
            "items": {
              "type": "string"
            }
          },
          "negative_prompt": {
            "description": "A negative prompt to guide the model",
            "type": "string",
            "title": "Negative Prompt",
            "default": ""
          }
        },
