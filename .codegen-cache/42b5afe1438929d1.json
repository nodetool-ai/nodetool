        "type": "object",
        "properties": {
          "prompt": {
            "examples": [
              "A serene Japanese garden with cherry blossoms, koi pond, and traditional wooden bridge at golden hour"
            ],
            "title": "Prompt",
            "type": "string",
            "description": "The prompt to generate an image from."
          },
          "num_images": {
            "minimum": 1,
            "title": "Number of Images",
            "type": "integer",
            "maximum": 4,
            "description": "The number of images to generate.",
            "default": 1
          },
          "acceleration": {
            "enum": [
              "none",
              "regular",
              "high"
            ],
            "title": "Acceleration",
            "type": "string",
            "description": "The acceleration level to use for image generation.",
            "default": "regular"
          },
          "image_size": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ImageSize"
              },
              {
                "enum": [
                  "square_hd",
                  "square",
                  "portrait_4_3",
                  "portrait_16_9",
                  "landscape_4_3",
                  "landscape_16_9"
                ],
                "type": "string"
              }
            ],
            "title": "Image Size",
            "description": "The size of the image to generate.",
            "default": "landscape_4_3"
          },
          "output_format": {
            "enum": [
              "jpeg",
              "png",
              "webp"
            ],
            "title": "Output Format",
            "type": "string",
            "description": "The format of the generated image.",
            "default": "png"
          },
          "loras": {
            "title": "Loras",
