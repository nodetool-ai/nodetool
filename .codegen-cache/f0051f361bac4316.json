      "StableDiffusionV35LargeInput": {
        "x-fal-order-properties": [
          "prompt",
          "negative_prompt",
          "num_inference_steps",
          "seed",
          "guidance_scale",
          "sync_mode",
          "num_images",
          "enable_safety_checker",
          "output_format",
          "controlnet",
          "image_size",
          "loras",
