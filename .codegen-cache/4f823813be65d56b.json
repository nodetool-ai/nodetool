        "required": [
          "video_url",
          "image_url"
        ]
      },
      "PikaV2PikadditionsOutput": {
        "description": "Output from Pikadditions generation",
        "type": "object",
        "properties": {
          "video": {
            "examples": [
              {
                "url": "https://v3.fal.media/files/lion/sbM48rVVi7y0yh5EuMtoC_output.mp4"
