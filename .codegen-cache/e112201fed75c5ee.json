            "enum": [
              "first",
              "middle",
              "last"
            ],
            "description": "Type of frame to extract: first, middle, or last frame of the video",
            "type": "string",
            "title": "Frame Type",
            "default": "first"
          }
        },
        "x-fal-order-properties": [
          "video_url",
          "frame_type"
        ],
        "required": [
          "video_url"
        ]
      },
      "FfmpegApiExtractFrameOutput": {
        "title": "FrameOutput",
        "type": "object",
