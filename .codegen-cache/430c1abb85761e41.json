            "maximum": 50,
            "title": "Num Inference Steps",
            "default": 28
          },
          "negative_prompt": {
            "description": "The negative prompt to guide what not to generate.",
            "type": "string",
            "title": "Negative Prompt",
            "default": ""
          },
          "num_frames": {
            "minimum": 1,
            "description": "The number of frames to generate.",
            "type": "integer",
            "maximum": 121,
            "title": "Num Frames",
            "default": 121
          }
        },
        "title": "HunyuanVideo15I2VRequest",
        "required": [
          "prompt",
          "image_url"
        ]
