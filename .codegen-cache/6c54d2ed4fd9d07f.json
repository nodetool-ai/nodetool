{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/kling-video/v2.6/pro/text-to-video",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/kling-video/v2.6/pro/text-to-video queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/kling-video/v2.6/pro/text-to-video",
