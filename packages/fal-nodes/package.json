{
  "name": "@nodetool-ai/fal-nodes",
  "type": "module",
  "version": "0.7.0-rc.18",
  "description": "FAL AI nodes for nodetool",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs && node -e \"require('node:fs').cpSync('src/fal-manifest.json', 'dist/fal-manifest.json')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fal-ai/client": "^1.9.4",
    "@nodetool-ai/node-sdk": "*",
    "@nodetool-ai/runtime": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./fal-manifest.json": "./dist/fal-manifest.json"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git",
    "directory": "packages/fal-nodes"
  },
  "homepage": "https://nodetool.ai",
  "bugs": {
    "url": "https://github.com/nodetool-ai/nodetool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
