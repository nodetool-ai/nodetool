        },
        "dynamic_properties": {},
        "dynamic_outputs": {}
      },
      {
        "id": "action_items_prompt",
        "parent_id": null,
        "type": "nodetool.text.Prompt",
        "data": {
          "prompt": "Read this meeting transcript and list every action item mentioned:\n\n{{TRANSCRIPT}}\n\nFor each action item capture who owns it and any deadline mentioned. If nothing was assigned to anyone, use \"Unassigned\". If no deadline was mentioned, use \"Not specified\". If the transcript has no action items at all, return zero rows."
        },
        "ui_properties": {
          "selected": false,
