        "type": "nodetool.text.Prompt",
        "data": {
          "prompt": "You are a study-flashcard writer. Create {{NUM_CARDS}} flashcards that teach {{TOPIC}} to a first-time learner.\n\nRules for every card:\n- \"front\": one clear question, term, or prompt — no compound questions.\n- \"back\": a concise, accurate answer, 1-2 sentences, no unexplained jargon.\n- \"category\": a short (2-3 word) tag grouping related cards (e.g. a sub-topic of {{TOPIC}}).\n- Cover distinct sub-topics — no duplicate or near-duplicate fronts.\n\nReturn exactly {{NUM_CARDS}} cards as rows with columns front, back, category. No commentary outside the rows."
        },
        "ui_properties": {
          "selected": false,
          "position": {
