      {
        "id": "prompt_images",
        "type": "nodetool.text.Prompt",
        "data": {
          "prompt": "You are an art director building a social-media image kit for a brand.\n\nBRAND\nName: {{ brand_name }}\nPositioning: {{ brand_description }}\n\nTASK\nWrite 4 distinct text-to-image prompts, one per asset listed below. Every prompt must:\n- describe a concrete scene, composition, lighting and color mood that fits the brand\n- leave clear negative space in the upper or lower third for a headline and logo overlay\n- be fully self-contained (never mention \"the brand\", \"our\", or the other prompts)\n- read as one vivid, comma-separated sentence a text-to-image model can render\n\nASSETS (write one prompt for each, in this exact order)\n1. Instagram square post, a hero product-in-context moment\n2. LinkedIn banner, calm and professional, wide horizon\n3. X / Twitter header, bold and energetic, high contrast\n4. Product announcement, clean studio look on a seamless backdrop\n\nOUTPUT\nReturn exactly 4 lines: one prompt per line, in order. No numbering, labels, quotes, or blank lines."
        },
        "ui_properties": {
          "position": {
            "x": 360,
            "y": 60
          },
          "zIndex": 0,
          "width": 300,
          "selectable": true,
          "bypassed": false,
          "title": "5️⃣ Write image prompts"
        },
        "dynamic_properties": {
          "brand_name": "Aurora Labs",
          "brand_description": "A climate-tech startup building friendly home-energy tools. Warm, optimistic and human, where nature meets precision engineering."
        },
        "dynamic_outputs": {}
