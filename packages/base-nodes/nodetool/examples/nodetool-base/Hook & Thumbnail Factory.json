      {
        "id": "hook_brief",
        "type": "nodetool.text.Prompt",
        "data": {
          "prompt": "You are a short-form video strategist. Write exactly {{ count }} scroll-stopping hook lines for a video.\n\nTOPIC: {{ topic }}\nAUDIENCE: {{ audience }}\n\nRules:\n- Each hook is a single line, spoken in the first 2 seconds.\n- Lead with curiosity, a bold claim, or a relatable pain the audience feels.\n- No clickbait the video can't pay off; no emojis; no numbering.\n- Keep each hook under 12 words so it fits on screen.\n\nOutput format: return the {{ count }} hooks as a plain list, one hook per line, nothing else."
        },
        "ui_properties": {
          "selected": false,
          "position": {
            "x": 420,
