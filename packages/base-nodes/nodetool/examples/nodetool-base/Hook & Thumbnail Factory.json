      {
        "id": "thumb_brief",
        "type": "nodetool.text.Prompt",
        "data": {
          "prompt": "You are an art director for viral thumbnails. Turn one hook into a single image description.\n\nVIDEO TOPIC: {{ topic }}\nHOOK ON SCREEN: {{ hook }}\n\nDescribe one bold, high-contrast 16:9 thumbnail: a clear focal subject, punchy saturated colors, dramatic lighting, and generous negative space on one side for a big text headline the creator will add later. Must read at small mobile sizes.\n\nConstraints: no words, letters, numbers, logos, or watermarks rendered in the image. No tiny details, no busy clutter.\n\nOutput format: one vivid paragraph, image description only."
        },
        "ui_properties": {
          "selected": false,
