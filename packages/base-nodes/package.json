{
  "name": "@nodetool/base-nodes",
  "type": "module",
  "version": "0.1.0",
  "description": "Basic nodetool-base node ports for the TS workflow runner",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "test": "vitest run",
    "test:all": "vitest run --config vitest.config.all.ts",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:metadata-parity": "vitest run tests/metadata-parity.test.ts",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@napi-rs/canvas": "^0.1.65",
    "@nodetool/agents": "*",
    "@nodetool/kie-nodes": "*",
    "@nodetool/config": "*",
    "@nodetool/code-runners": "*",
    "@nodetool/kernel": "*",
    "@nodetool/node-sdk": "*",
    "@nodetool/runtime": "*",
    "@nodetool/vectorstore": "*",
    "@supabase/supabase-js": "^2.98.0",
    "better-sqlite3": "^12.8.0",
    "chart.js": "^4.5.1",
    "cheerio": "^1.2.0",
    "docx": "^9.6.0",
    "exceljs": "^4.4.0",
    "html-to-text": "^9.0.5",
    "linkedom": "^0.18.9",
    "mammoth": "^1.11.0",
    "node-web-audio-api": "^1.0.8",
    "nodemailer": "^8.0.5",
    "pdfjs-dist": "^5.5.207",
    "playwright": "^1.58.2",
    "sharp": "^0.34.4",
    "soundtouchjs": "^0.3.0",
    "turndown": "^7.2.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
