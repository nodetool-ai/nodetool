{
  "name": "@nodetool/models",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "nodetool-dev": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./secret": {
      "nodetool-dev": "./src/secret.ts",
      "import": "./dist/secret.js",
      "types": "./dist/secret.d.ts"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-ts-build.mjs && tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@nodetool/config": "*",
    "@nodetool/protocol": "*",
    "@nodetool/security": "*",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
