{
  "name": "@nodetool-ai/websocket",
  "version": "0.7.0-rc.23",
  "type": "module",
  "description": "Unified websocket runner for workflow and chat operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs",
    "build:all": "node ../../scripts/build-websocket-workspaces.mjs",
    "build:stale": "node ../../scripts/build-stale-websocket-workspaces.mjs",
    "dev": "node ../../scripts/run-websocket-dev.mjs server",
    "dev:fast": "node ../../scripts/run-websocket-dev.mjs server stale",
    "test-ui": "node ../../scripts/run-websocket-dev.mjs test-ui",
    "devserver": "npm run test-ui",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^9.1.1",
    "@fastify/websocket": "^11.0.1",
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nodetool-ai/agents": "*",
    "@nodetool-ai/automation-nodes": "*",
    "@nodetool-ai/auth": "*",
    "@nodetool-ai/base-nodes": "*",
    "@nodetool-ai/chat": "*",
    "@nodetool-ai/config": "*",
    "@nodetool-ai/dsl": "*",
    "@nodetool-ai/image-editor": "*",
    "@nodetool-ai/elevenlabs-nodes": "*",
    "@nodetool-ai/minimax-nodes": "*",
    "@nodetool-ai/transformers-js-nodes": "*",
    "@nodetool-ai/transformers-js-provider": "*",
    "@nodetool-ai/fal-nodes": "*",
    "@nodetool-ai/kie-nodes": "*",
    "@nodetool-ai/topaz-nodes": "*",
    "@nodetool-ai/reve-nodes": "*",
    "@nodetool-ai/atlascloud-nodes": "*",
    "@nodetool-ai/together-nodes": "*",
    "@nodetool-ai/huggingface": "*",
    "@nodetool-ai/huggingface-nodes": "*",
    "@nodetool-ai/kernel": "*",
    "@nodetool-ai/models": "*",
    "@nodetool-ai/node-sdk": "*",
    "@nodetool-ai/protocol": "*",
    "@nodetool-ai/replicate-nodes": "*",
    "@nodetool-ai/runtime": "*",
    "@nodetool-ai/security": "*",
    "@nodetool-ai/storage": "*",
    "@nodetool-ai/timeline": "*",
    "@nodetool-ai/vectorstore": "*",
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@sinclair/typebox": "^0.34.0",
    "fastify": "^5.8.5",
    "fflate": "^0.8.2",
    "@trpc/server": "^11.0.0",
    "@hyzyla/pdfium": "^2.1.12",
    "jszip": "^3.10.1",
    "msgpackr": "^1.11.2",
    "sharp": "^0.34.5",
    "superjson": "^2.2.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "nodetool-dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./trpc": {
      "nodetool-dev": "./src/trpc/router.ts",
      "types": "./dist/trpc/router.d.ts",
      "import": "./dist/trpc/router.js",
      "default": "./dist/trpc/router.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git",
    "directory": "packages/websocket"
  },
  "homepage": "https://nodetool.ai",
  "bugs": {
    "url": "https://github.com/nodetool-ai/nodetool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
