{
  "name": "@nodetool/websocket",
  "version": "0.1.0",
  "type": "module",
  "description": "Unified websocket runner for workflow and chat operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs",
    "build:all": "node ../../scripts/build-websocket-workspaces.mjs",
    "build:stale": "node ../../scripts/build-stale-websocket-workspaces.mjs",
    "dev": "node ../../scripts/run-websocket-dev.mjs server",
    "dev:fast": "node ../../scripts/run-websocket-dev.mjs server stale",
    "test-ui": "node ../../scripts/run-websocket-dev.mjs test-ui",
    "devserver": "npm run test-ui",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^9.1.1",
    "@fastify/websocket": "^11.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nodetool/agents": "*",
    "@nodetool/auth": "*",
    "@nodetool/base-nodes": "*",
    "@nodetool/config": "*",
    "@nodetool/dsl": "*",
    "@nodetool/elevenlabs-nodes": "*",
    "@nodetool/fal-nodes": "*",
    "@nodetool/kie-nodes": "*",
    "@nodetool/huggingface": "*",
    "@nodetool/kernel": "*",
    "@nodetool/models": "*",
    "@nodetool/node-sdk": "*",
    "@nodetool/protocol": "*",
    "@nodetool/replicate-nodes": "*",
    "@nodetool/runtime": "*",
    "@nodetool/security": "*",
    "@nodetool/vectorstore": "*",
    "@mariozechner/pi-coding-agent": "^0.67.4",
    "@openai/codex-sdk": "^0.118.0",
    "@opencode-ai/sdk": "^1.3.15",
    "fastify": "^5.8.5",
    "msgpackr": "^1.11.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "nodetool-dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
