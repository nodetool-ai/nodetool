{
  "name": "@nodetool/websocket",
  "version": "0.1.0",
  "type": "module",
  "description": "Unified websocket runner for workflow and chat operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:all": "node ../../scripts/build-websocket-workspaces.mjs",
    "dev": "node ../../scripts/run-websocket-dev.mjs server",
    "test-ui": "node ../../scripts/run-websocket-dev.mjs test-ui",
    "devserver": "npm run test-ui",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nodetool/agents": "*",
    "@nodetool/auth": "*",
    "@nodetool/base-nodes": "*",
    "@nodetool/config": "*",
    "@nodetool/kernel": "*",
    "@nodetool/models": "*",
    "@nodetool/node-sdk": "*",
    "@nodetool/protocol": "*",
    "@nodetool/runtime": "*",
    "@nodetool/security": "*",
    "chromadb": "^3.3.1",
    "msgpackr": "^1.11.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
