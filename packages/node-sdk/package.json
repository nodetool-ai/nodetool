{
  "name": "@nodetool/node-sdk",
  "type": "module",
  "version": "0.1.0",
  "description": "Node SDK: BaseNode, NodeRegistry, and example nodes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs",
    "test": "vitest run",
    "test:metadata": "vitest run tests/metadata.test.ts",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@nodetool/kernel": "*",
    "@nodetool/protocol": "*",
    "@nodetool/runtime": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
