{
  "name": "@nodetool-ai/together-nodes",
  "type": "module",
  "version": "0.7.0-rc.23",
  "description": "Together AI nodes for NodeTool — serverless image (FLUX / Imagen / Ideogram / Seedream), video (Veo / Sora / Kling / Seedance / MiniMax), text-to-speech (Orpheus / Kokoro / Cartesia) and transcription (Whisper / Voxtral / Parakeet)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "gen:manifest": "node scripts/generate-manifest.mjs",
    "build": "node ../../scripts/build-typescript-workspace.mjs && node -e \"require('node:fs').cpSync('src/together-manifest.json', 'dist/together-manifest.json')\"",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@nodetool-ai/node-sdk": "*",
    "@nodetool-ai/runtime": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./together-manifest.json": "./dist/together-manifest.json"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git",
    "directory": "packages/together-nodes"
  },
  "homepage": "https://nodetool.ai",
  "bugs": {
    "url": "https://github.com/nodetool-ai/nodetool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
