{
  "name": "@nodetool-ai/image-editor",
  "version": "0.7.0-rc.32",
  "description": "Shared image-editor types, dependency hashing, and seeded layer templates",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs",
    "check": "npm run lint && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "nodetool-dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dependencyHash.js": {
      "nodetool-dev": "./src/dependencyHash.ts",
      "types": "./dist/dependencyHash.d.ts",
      "import": "./dist/dependencyHash.js",
      "default": "./dist/dependencyHash.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git",
    "directory": "packages/image-editor"
  },
  "homepage": "https://nodetool.ai",
  "bugs": {
    "url": "https://github.com/nodetool-ai/nodetool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "nodetool",
    "ai",
    "workflow",
    "workflow-automation",
    "typescript",
    "image-editor",
    "layers",
    "canvas",
    "editor"
  ]
}
