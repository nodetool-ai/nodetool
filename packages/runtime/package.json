{
  "name": "@nodetool-ai/runtime",
  "version": "0.7.0-rc.27",
  "description": "Processing context, message queue, and output normalization",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs && node -e \"require('node:fs').mkdirSync('dist/providers',{recursive:true}); require('node:fs').cpSync('src/providers/aki-manifest.json', 'dist/providers/aki-manifest.json')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aki-io/aki-io": "^1.0.1",
    "@anthropic-ai/sdk": "^0.105.0",
    "@nodetool-ai/config": "*",
    "@nodetool-ai/protocol": "*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.203.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@pydantic/genai-prices": "^0.0.62",
    "js-tiktoken": "^1.0.21",
    "openai": "^6.35.0",
    "replicate": "^1.4.0",
    "sharp": "^0.34.5",
    "ws": "^8.19.0",
    "msgpackr": "^1.11.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.190",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.190"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "nodetool-dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./oauth": {
      "nodetool-dev": "./src/providers/oauth/index.ts",
      "types": "./dist/providers/oauth/index.d.ts",
      "import": "./dist/providers/oauth/index.js",
      "default": "./dist/providers/oauth/index.js"
    },
    "./context": {
      "nodetool-dev": "./src/context.ts",
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js",
      "default": "./dist/context.js"
    },
    "./media-ref-bytes": {
      "nodetool-dev": "./src/media-ref-bytes.ts",
      "types": "./dist/media-ref-bytes.d.ts",
      "import": "./dist/media-ref-bytes.js",
      "default": "./dist/media-ref-bytes.js"
    },
    "./prompt-asset-refs": {
      "nodetool-dev": "./src/prompt-asset-refs.ts",
      "types": "./dist/prompt-asset-refs.d.ts",
      "import": "./dist/prompt-asset-refs.js",
      "default": "./dist/prompt-asset-refs.js"
    },
    "./tracing": {
      "nodetool-dev": "./src/tracing-helpers.ts",
      "types": "./dist/tracing-helpers.d.ts",
      "import": "./dist/tracing-helpers.js",
      "default": "./dist/tracing-helpers.js"
    },
    "./zod-schema": {
      "nodetool-dev": "./src/zod-schema.ts",
      "types": "./dist/zod-schema.d.ts",
      "import": "./dist/zod-schema.js",
      "default": "./dist/zod-schema.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://nodetool.ai",
  "bugs": {
    "url": "https://github.com/nodetool-ai/nodetool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
