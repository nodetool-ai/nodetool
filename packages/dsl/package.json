{
  "name": "@nodetool/dsl",
  "type": "module",
  "version": "0.1.0",
  "description": "Type-safe TypeScript DSL for defining NodeTool workflows",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "nodetool-dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-ts-build.mjs && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "codegen": "tsx scripts/codegen.ts"
  },
  "dependencies": {
    "@nodetool/base-nodes": "*",
    "@nodetool/elevenlabs-nodes": "*",
    "@nodetool/protocol": "*",
    "@nodetool/kernel": "*",
    "@nodetool/node-sdk": "*",
    "@nodetool/runtime": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
}
