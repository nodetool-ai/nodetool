{
  "name": "@nodetool/dsl",
  "type": "module",
  "version": "0.1.0",
  "description": "Type-safe TypeScript DSL for defining NodeTool workflows",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "codegen": "tsx scripts/codegen.ts"
  },
  "dependencies": {
    "@nodetool/base-nodes": "*",
    "@nodetool/protocol": "*",
    "@nodetool/kernel": "*",
    "@nodetool/node-sdk": "*",
    "@nodetool/runtime": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
