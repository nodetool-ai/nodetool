{
  "name": "@nodetool-ai/dsl",
  "type": "module",
  "version": "0.7.0-rc.23",
  "description": "Type-safe TypeScript DSL for defining NodeTool workflows",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "nodetool-dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "codegen": "tsx scripts/codegen.ts"
  },
  "dependencies": {
    "@nodetool-ai/base-nodes": "*",
    "@nodetool-ai/elevenlabs-nodes": "*",
    "@nodetool-ai/transformers-js-nodes": "*",
    "@nodetool-ai/protocol": "*",
    "@nodetool-ai/kernel": "*",
    "@nodetool-ai/node-sdk": "*",
    "@nodetool-ai/runtime": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git",
    "directory": "packages/dsl"
  },
  "homepage": "https://nodetool.ai",
  "bugs": {
    "url": "https://github.com/nodetool-ai/nodetool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
