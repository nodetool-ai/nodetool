      {
        "name": "face_enhancement_creativity",
        "type": "float",
        "default": 0.3,
        "title": "Face Enhancement Creativity",
        "description": "Realistic (0) ↔ creative (1) face recovery.",
        "required": false,
        "min": 0.0,
        "max": 1.0
      },
      {
        "name": "sharpen",
        "type": "float",
        "default": 0.0,
        "title": "Sharpen",
        "description": "Sharpening strength.",
        "required": false,
        "min": 0.0,
        "max": 1.0
      },
      {
        "name": "denoise",
        "type": "float",
        "default": 0.0,
        "title": "Denoise",
        "description": "Noise reduction strength.",
        "required": false,
        "min": 0.0,
        "max": 1.0
      },
      {
        "name": "fix_compression",
        "type": "float",
        "default": 0.0,
        "title": "Fix Compression",
        "description": "Reduce JPEG/compression artifacts.",
        "required": false,
        "min": 0.0,
        "max": 1.0
      },
      {
        "name": "subject_detection",
        "type": "enum",
        "default": "",
