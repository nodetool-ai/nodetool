        "name": "model",
        "type": "enum",
        "default": "Standard V2",
        "title": "Model",
        "description": "Topaz precision image model.",
        "required": false,
        "values": [
          "Standard V2",
          "High Fidelity V2",
          "Upscale High Fidelity V3",
          "Low Resolution V2",
          "CGI",
          "Text Refine"
