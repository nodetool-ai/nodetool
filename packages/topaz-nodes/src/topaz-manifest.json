        "min": 0
      },
      {
        "name": "output_height",
        "type": "int",
        "default": 0,
        "title": "Output Height",
        "description": "Output height in pixels. Leave 0 to derive from scale.",
        "required": false,
        "min": 0
      },
      {
        "name": "scale",
        "type": "float",
        "default": 2.0,
        "title": "Scale",
        "description": "Upscale factor when output_width and output_height are both 0.",
        "required": false,
        "min": 1.0,
        "max": 6.0
