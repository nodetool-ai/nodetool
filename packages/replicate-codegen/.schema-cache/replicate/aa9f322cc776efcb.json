{
  "modelId": "resemble-ai/chatterbox-pro",
  "owner": "resemble-ai",
  "name": "chatterbox-pro",
  "version": "301e12652e84fbba1524e5f2758a9a92c6bd205792304f53c057b7f9ab091342",
  "description": "Generate expressive, natural speech with Resemble AI's Chatterbox.",
  "inputSchema": {
    "properties": {
      "custom_voice": {
        "description": "The uuid of the voice to use (this overrides the voice selection)",
        "nullable": true,
        "title": "Custom Voice",
        "type": "string",
        "x-order": 2
      },
      "exaggeration": {
        "default": 0.5,
        "description": "Exaggeration (Neutral = 0.5, extreme values can be unstable)",
        "maximum": 1,
        "minimum": 0.1,
        "title": "Exaggeration",
        "type": "number",
        "x-order": 3
      },
      "pitch": {
        "default": "medium",
        "description": "Pitch",
        "enum": [
          "x-low",
          "low",
          "medium",
          "high",
          "x-high"
        ],
        "title": "pitch",
        "type": "string",
        "x-order": 6
      },
      "prompt": {
        "description": "Text to synthesize",
        "title": "Prompt",
        "type": "string",
        "x-order": 0
      },
      "seed": {
        "description": "Random seed. Set for reproducible generation",
        "nullable": true,
        "title": "Seed",
        "type": "integer",
        "x-order": 5
      },
      "temperature": {
        "default": 0.8,
        "description": "Temperature",
        "maximum": 5,
        "minimum": 0.1,
        "title": "Temperature",
        "type": "number",
        "x-order": 4
      },
      "voice": {
        "default": "Luna",
        "description": "Choose a predefined voice",
        "enum": [
          "Luna",
          "Ember",
          "Hem",
          "Aurora",
          "Cliff",
          "Josh",
          "William (Whispering)",
          "Orion",
          "Ken"
        ],
        "title": "voice",
        "type": "string",
        "x-order": 1
      }
    },
    "required": [
      "prompt"
    ],
    "title": "Input",
    "type": "object"
  },
  "outputSchema": {
    "format": "uri",
    "title": "Output",
    "type": "string"
  }
}