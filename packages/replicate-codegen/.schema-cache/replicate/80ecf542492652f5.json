{
  "modelId": "andreasjansson/musicgen-looper",
  "owner": "andreasjansson",
  "name": "musicgen-looper",
  "version": "f8140d0457c2b39ad8728a80736fea9a67a0ec0cd37b35f40b68cce507db2366",
  "description": "Generate fixed-bpm loops from text prompts",
  "inputSchema": {
    "properties": {
      "bpm": {
        "default": 140,
        "description": "Tempo in beats per minute",
        "maximum": 300,
        "minimum": 40,
        "title": "Bpm",
        "type": "number",
        "x-order": 1
      },
      "classifier_free_guidance": {
        "default": 3,
        "description": "Increases the influence of inputs on the output. Higher values produce lower-varience outputs that adhere more closely to inputs.",
        "title": "Classifier Free Guidance",
        "type": "integer",
        "x-order": 8
      },
      "max_duration": {
        "default": 8,
        "description": "Maximum duration of the generated loop in seconds.",
        "maximum": 20,
        "minimum": 2,
        "title": "Max Duration",
        "type": "integer",
        "x-order": 3
      },
      "model_version": {
        "default": "medium",
        "description": "Model to use for generation. .",
        "enum": [
          "medium",
          "large"
        ],
        "title": "model_version",
        "type": "string",
        "x-order": 4
      },
      "output_format": {
        "default": "wav",
        "description": "Output format for generated audio.",
        "enum": [
          "wav",
          "mp3"
        ],
        "title": "output_format",
        "type": "string",
        "x-order": 9
      },
      "prompt": {
        "description": "A description of the music you want to generate.",
        "title": "Prompt",
        "type": "string",
        "x-order": 0
      },
      "seed": {
        "default": -1,
        "description": "Seed for random number generator. If None or -1, a random seed will be used.",
        "title": "Seed",
        "type": "integer",
        "x-order": 10
      },
      "temperature": {
        "default": 1,
        "description": "Controls the 'conservativeness' of the sampling process. Higher temperature means more diversity.",
        "title": "Temperature",
        "type": "number",
        "x-order": 7
      },
      "top_k": {
        "default": 250,
        "description": "Reduces sampling to the k most likely tokens.",
        "title": "Top K",
        "type": "integer",
        "x-order": 5
      },
      "top_p": {
        "default": 0,
        "description": "Reduces sampling to tokens with cumulative probability of p. When set to  `0` (default), top_k sampling is used.",
        "title": "Top P",
        "type": "number",
        "x-order": 6
      },
      "variations": {
        "default": 4,
        "description": "Number of variations to generate",
        "maximum": 20,
        "minimum": 1,
        "title": "Variations",
        "type": "integer",
        "x-order": 2
      }
    },
    "required": [
      "prompt"
    ],
    "title": "Input",
    "type": "object"
  },
