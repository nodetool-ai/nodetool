        "title": "Prompt",
        "type": "string",
        "x-order": 1
      },
      "seed": {
        "description": "Set a seed for reproducibility. Random by default.",
        "title": "Seed",
        "type": "integer",
        "x-order": 10
      },
      "width": {
        "default": 1024,
        "description": "Width of the output image (ignored if structure image given)",
        "title": "Width",
        "type": "integer",
        "x-order": 3
      }
