{
  "modelId": "fofr/audio-to-waveform",
  "owner": "fofr",
  "name": "audio-to-waveform",
  "version": "116cf9b97d0a117cfe64310637bf99ae8542cc35d813744c6ab178a3e134ff5a",
  "description": "Create a waveform video from audio",
  "inputSchema": {
    "properties": {
      "audio": {
        "description": "Audio file to create waveform from",
        "format": "uri",
        "title": "Audio",
        "type": "string",
        "x-order": 0
      },
      "bar_count": {
        "default": 100,
        "description": "Number of bars in waveform",
        "title": "Bar Count",
        "type": "integer",
        "x-order": 4
      },
      "bar_width": {
        "default": 0.4,
        "description": "Width of bars in waveform. 1 represents full width, 0.5 represents half width, etc.",
        "title": "Bar Width",
        "type": "number",
        "x-order": 5
      },
      "bars_color": {
        "default": "#ffffff",
        "description": "Color of waveform bars",
        "title": "Bars Color",
        "type": "string",
        "x-order": 3
      },
      "bg_color": {
        "default": "#000000",
        "description": "Background color of waveform",
        "title": "Bg Color",
        "type": "string",
        "x-order": 1
      },
      "caption_text": {
        "default": "",
        "description": "Caption text for the video",
        "title": "Caption Text",
        "type": "string",
        "x-order": 6
      },
      "fg_alpha": {
        "default": 0.75,
        "description": "Opacity of foreground waveform",
        "title": "Fg Alpha",
        "type": "number",
        "x-order": 2
      }
    },
    "required": [
      "audio"
    ],
    "title": "Input",
    "type": "object"
  },
  "outputSchema": {
    "format": "uri",
    "title": "Output",
    "type": "string"
  }
}