        "x-order": 5
      },
      "prompt": {
        "default": "",
        "description": "Prompt",
        "title": "Prompt",
        "type": "string",
        "x-order": 4
      },
      "seed": {
        "description": "Random seed. Leave blank to randomize the seed",
