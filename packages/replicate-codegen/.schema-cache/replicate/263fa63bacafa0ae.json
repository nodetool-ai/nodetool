        "type": "integer",
        "x-order": 6
      },
      "source_image": {
        "description": "Source image of body",
        "format": "uri",
        "title": "Source Image",
        "type": "string",
        "x-order": 2
      },
      "strength": {
        "default": 0.7,
        "description": "mask strength",
        "title": "Strength",
        "type": "number",
        "x-order": 3
      }
