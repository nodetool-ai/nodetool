        "title": "Blur Amount",
        "type": "number",
        "x-order": 1
      },
      "face_image": {
        "description": "Input face image",
        "format": "uri",
        "title": "Face Image",
        "type": "string",
        "x-order": 0
      },
      "num_outputs": {
