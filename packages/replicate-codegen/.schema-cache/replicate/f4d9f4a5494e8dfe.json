        "description": "Control the strength of dilated sampling",
        "title": "Cosine Scale 2",
        "type": "number",
        "x-order": 10
      },
      "cosine_scale_3": {
        "default": 1,
        "description": "Control the strength of the Gaussian filter",
        "title": "Cosine Scale 3",
        "type": "number",
        "x-order": 11
      },
      "guidance_scale": {
        "default": 8.5,
