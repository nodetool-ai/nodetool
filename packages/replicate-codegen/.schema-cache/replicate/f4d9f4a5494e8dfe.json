        "x-order": 6
      },
      "image": {
        "description": "Input image",
        "format": "uri",
        "title": "Image",
        "type": "string",
        "x-order": 0
      },
      "multi_decoder": {
        "default": false,
        "description": "Use multiple decoders",
        "title": "Multi Decoder",
        "type": "boolean",
        "x-order": 13
      },
      "negative_prompt": {
        "default": "blurry, ugly, duplicate, poorly drawn, deformed, mosaic",
