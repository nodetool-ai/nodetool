{
  "modelId": "bytedance/seedance-1-pro",
  "owner": "bytedance",
  "name": "seedance-1-pro",
  "version": "a5fd550893da3b6f67997812759065652454ddaca10e96b83b59cbae1814cb36",
  "description": "A pro version of Seedance that offers text-to-video and image-to-video support for 5s or 10s videos, at 480p and 1080p resolution",
  "inputSchema": {
    "properties": {
      "aspect_ratio": {
        "default": "16:9",
        "description": "Video aspect ratio. Ignored if an image is used.",
        "enum": [
          "16:9",
          "4:3",
          "1:1",
          "3:4",
          "9:16",
          "21:9",
          "9:21"
        ],
        "title": "aspect_ratio",
        "type": "string",
        "x-order": 5
      },
      "camera_fixed": {
        "default": false,
        "description": "Whether to fix camera position",
        "title": "Camera Fixed",
        "type": "boolean",
        "x-order": 7
      },
      "duration": {
        "default": 5,
        "description": "Video duration in seconds",
        "maximum": 12,
        "minimum": 2,
        "title": "Duration",
        "type": "integer",
        "x-order": 3
      },
      "fps": {
        "default": 24,
        "description": "Frame rate (frames per second)",
        "enum": [
          24
        ],
        "title": "fps",
        "type": "integer",
        "x-order": 6
      },
      "image": {
        "description": "Input image for image-to-video generation",
        "format": "uri",
        "nullable": true,
        "title": "Image",
        "type": "string",
        "x-order": 1
      },
      "last_frame_image": {
        "description": "Input image for last frame generation. This only works if an image start frame is given too.",
        "format": "uri",
        "nullable": true,
        "title": "Last Frame Image",
        "type": "string",
        "x-order": 2
      },
      "prompt": {
        "description": "Text prompt for video generation",
        "title": "Prompt",
        "type": "string",
        "x-order": 0
      },
      "resolution": {
        "default": "1080p",
        "description": "Video resolution",
        "enum": [
          "480p",
          "720p",
          "1080p"
        ],
        "title": "resolution",
        "type": "string",
        "x-order": 4
      },
      "seed": {
        "description": "Random seed. Set for reproducible generation",
        "nullable": true,
        "title": "Seed",
        "type": "integer",
        "x-order": 8
      }
    },
    "required": [
      "prompt"
    ],
    "title": "Input",
    "type": "object"
  },
  "outputSchema": {
    "format": "uri",
    "title": "Output",
    "type": "string"
  }
}