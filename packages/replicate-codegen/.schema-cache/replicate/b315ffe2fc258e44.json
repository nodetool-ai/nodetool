        "enum": [
          "1:1",
          "9:16",
          "16:9",
          "3:4",
          "4:3"
        ],
        "title": "aspect_ratio",
        "type": "string",
        "x-order": 1
      },
      "output_format": {
        "default": "jpg",
        "description": "Format of the output image",
        "enum": [
          "jpg",
          "png"
        ],
        "title": "output_format",
        "type": "string",
        "x-order": 3
      },
      "prompt": {
        "description": "Text prompt for image generation",
        "title": "Prompt",
        "type": "string",
        "x-order": 0
      },
      "safety_filter_level": {
