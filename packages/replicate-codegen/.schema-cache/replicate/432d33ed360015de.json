        "description": "Aspect ratio of the generated image. Use 'match_input_image' to match the aspect ratio of the input image.",
        "enum": [
          "match_input_image",
          "1:1",
          "16:9",
          "9:16",
          "4:3",
          "3:4",
          "3:2",
          "2:3",
          "4:5",
          "5:4",
          "21:9",
          "9:21",
          "2:1",
          "1:2"
        ],
        "title": "aspect_ratio",
        "type": "string",
        "x-order": 3
      },
      "background": {
        "default": "neutral",
        "description": "The background of the headshot",
        "enum": [
          "white",
          "black",
          "neutral",
          "gray",
          "office"
        ],
        "title": "background",
        "type": "string",
        "x-order": 2
      },
      "gender": {
        "default": "none",
        "description": "The gender of the person",
        "enum": [
          "none",
          "male",
          "female"
        ],
        "title": "gender",
        "type": "string",
        "x-order": 1
      },
      "input_image": {
        "description": "Image of the person to create a professional headshot for. Must be jpeg, png, gif, or webp.",
