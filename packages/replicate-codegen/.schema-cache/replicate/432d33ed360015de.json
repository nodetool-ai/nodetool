        "minimum": 0,
        "title": "Safety Tolerance",
        "type": "integer"
      },
      "seed": {
        "description": "Random seed. Set for reproducible generation",
        "nullable": true,
        "title": "Seed",
        "type": "integer"
      }
    },
    "required": [
      "input_image"
