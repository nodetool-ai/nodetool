{
  "modelId": "runwayml/gen4-turbo",
  "owner": "runwayml",
  "name": "gen4-turbo",
  "version": "6257a44f7b6390e47eb18a1c11f55d221fc90ec056d9acfe490ec9924739533c",
  "description": "Generate 5s and 10s 720p videos fast",
  "inputSchema": {
    "properties": {
      "aspect_ratio": {
        "default": "16:9",
        "description": "Video aspect ratio",
        "enum": [
          "16:9",
          "9:16",
          "4:3",
          "3:4",
          "1:1",
          "21:9"
        ],
        "title": "aspect_ratio",
        "type": "string",
        "x-order": 2
      },
      "duration": {
        "default": 5,
        "description": "Duration of the output video in seconds",
        "enum": [
          5,
          10
        ],
        "title": "duration",
        "type": "integer",
        "x-order": 3
      },
      "image": {
        "description": "Initial image for video generation (first frame)",
        "format": "uri",
        "title": "Image",
        "type": "string"
      },
      "prompt": {
        "description": "Text prompt for video generation",
        "title": "Prompt",
        "type": "string"
      },
      "seed": {
        "description": "Random seed. Set for reproducible generation",
        "nullable": true,
        "title": "Seed",
        "type": "integer"
      }
    },
    "required": [
      "prompt",
      "image"
    ],
    "title": "Input",
    "type": "object"
  },
  "outputSchema": {
    "format": "uri",
    "title": "Output",
    "type": "string"
  }
}