{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": [
    "html",
    "json",
    "clear-text",
    "progress"
  ],
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "!src/index.ts"
  ],
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "timeoutMS": 60000,
  "concurrency": 4
}
