 const STORAGE_ENV_KEYS = [
   "NODETOOL_STORAGE_BACKEND",
-  "S3_BUCKET",
   "S3_REGION",
   "S3_ENDPOINT",
   "S3_PREFIX",
-  "SUPABASE_STORAGE_URL",
-  "SUPABASE_STORAGE_SERVICE_KEY",
-  "SUPABASE_STORAGE_BUCKET",
-  "SUPABASE_STORAGE_PREFIX",
+  "SUPABASE_URL",
