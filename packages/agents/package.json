{
  "name": "@nodetool-ai/agents",
  "version": "0.7.0-rc.16",
  "description": "Agent system for planning and executing multi-step LLM tasks",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@jitl/quickjs-ng-wasmfile-release-sync": "^0.31.0",
    "@llamaindex/liteparse": "^1.5.2",
    "@nodetool-ai/config": "*",
    "@nodetool-ai/kernel": "*",
    "@nodetool-ai/models": "*",
    "@nodetool-ai/node-sdk": "*",
    "@nodetool-ai/protocol": "*",
    "@nodetool-ai/runtime": "*",
    "@sebastianwessel/quickjs": "^3.0.1",
    "@types/mailparser": "^3.4.6",
    "imapflow": "^1.2.12",
    "js-tiktoken": "^1.0.18",
    "mailparser": "^3.9.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "nodetool-dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tool": {
      "nodetool-dev": "./src/tools/base-tool.ts",
      "types": "./dist/tools/base-tool.d.ts",
      "import": "./dist/tools/base-tool.js",
      "default": "./dist/tools/base-tool.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git",
    "directory": "packages/agents"
  },
  "homepage": "https://nodetool.ai",
  "bugs": {
    "url": "https://github.com/nodetool-ai/nodetool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
