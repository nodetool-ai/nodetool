    "@nodetool/protocol": "*",
    "@nodetool/runtime": "*",
    "@nodetool/security": "*",
    "chalk": "^5.3.0",
    "ws": "^8.18.3",
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^12.0.0",
    "marked-terminal": "^7.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "vitest": "^1.6.1",
    "typescript": "^5.4.5"
