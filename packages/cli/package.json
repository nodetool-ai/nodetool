{
  "name": "@nodetool/cli",
  "version": "0.1.0",
  "description": "NodeTool chat CLI — interactive AI chat with agent mode and tool support",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nodetool-chat": "dist/index.js",
    "nodetool": "dist/nodetool.js"
