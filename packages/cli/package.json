{
  "name": "@nodetool/cli",
  "version": "0.1.0",
  "description": "NodeTool chat CLI — interactive AI chat with agent mode and tool support",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nodetool-chat": "dist/index.js",
    "nodetool": "dist/nodetool.js"
  },
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@nodetool/config": "*",
    "@nodetool/agents": "*",
    "@nodetool/base-nodes": "*",
    "@nodetool/elevenlabs-nodes": "*",
    "@nodetool/dsl": "*",
    "@nodetool/fal-nodes": "*",
    "@nodetool/replicate-nodes": "*",
    "@nodetool/kernel": "*",
    "@nodetool/models": "*",
    "@nodetool/node-sdk": "*",
    "@nodetool/chat": "*",
    "@nodetool/protocol": "*",
    "@nodetool/runtime": "*",
    "@nodetool/security": "*",
    "@inquirer/prompts": "^5.0.0",
    "chalk": "^5.3.0",
    "ws": "^8.18.3",
    "commander": "^12.1.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "marked": "^12.0.0",
    "marked-terminal": "^7.1.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "vitest": "^4.1.2",
    "typescript": "^5.7.2"
  },
  "exports": {
    ".": {
      "nodetool-dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
