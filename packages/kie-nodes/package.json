{
  "name": "@nodetool/kie-nodes",
  "type": "module",
  "version": "0.1.0",
  "description": "Kie.ai model nodes for the TS workflow runner",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs && node -e \"require('node:fs').cpSync('src/kie-manifest.json', 'dist/kie-manifest.json')\"",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@nodetool/node-sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./kie-manifest.json": "./src/kie-manifest.json"
  }
}
