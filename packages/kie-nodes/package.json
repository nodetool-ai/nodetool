{
  "name": "@nodetool-ai/kie-nodes",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "version": "0.7.0-rc.27",
  "description": "Kie.ai model nodes for the TS workflow runner",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-typescript-workspace.mjs && node -e \"const fs=require('node:fs'); fs.cpSync('src/kie-manifest.json','dist/kie-manifest.json'); if (fs.existsSync('src/generated')) fs.cpSync('src/generated','dist/generated',{recursive:true});\"",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@nodetool-ai/node-sdk": "*",
    "@nodetool-ai/runtime": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./kie-manifest.json": "./dist/kie-manifest.json",
    "./kie-pricing-api": {
      "nodetool-dev": "./src/kie-pricing-api.ts",
      "types": "./dist/kie-pricing-api.d.ts",
      "import": "./dist/kie-pricing-api.js",
      "default": "./dist/kie-pricing-api.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodetool-ai/nodetool.git",
    "directory": "packages/kie-nodes"
  },
  "homepage": "https://nodetool.ai",
  "bugs": {
    "url": "https://github.com/nodetool-ai/nodetool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
